---
import BookingButton from "./BookingButton.astro";
import { SITE } from "../data/site";

const bg =
  "https://images.unsplash.com/photo-1562320340-20b163c733bf?auto=format&fit=crop&w=2000&q=85";
---

<section class="final-cta section" aria-labelledby="final-cta-heading">
  <div class="final-cta__media" aria-hidden="true">
    <img
      src={bg}
      alt=""
      width={2000}
      height={1125}
      loading="lazy"
      decoding="async"
      class="final-cta__img"
    />
  </div>
  <div class="final-cta__scrim" aria-hidden="true"></div>

  <div class="container final-cta__inner" data-reveal>
    <p class="final-cta__eyebrow">Planity</p>
    <h2 id="final-cta-heading" class="final-cta__title display-lg">
      Ihr Termin — in wenigen Schritten reserviert
    </h2>
    <p class="final-cta__lead">
      Wählen Sie Leistung, Datum und Lieblingszeit. Sie sehen Verfügbarkeiten live — ohne Warteschleife, ohne Rätselraten.
      {SITE.name} freut sich darauf, Sie im Salon zu begrüßen.
    </p>
    <div class="final-cta__actions">
      <BookingButton variant="on-dark" />
      <p class="final-cta__hint">
        Link öffnet die offizielle Planity-Seite für unseren Meisterbetrieb in {SITE.city}.
      </p>
    </div>
  </div>
</section>

<style>
  .final-cta {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-2xl);
    color: #faf8f5;
  }

  .final-cta__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .final-cta__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 45%;
    filter: saturate(1.05) brightness(0.92);
  }

  /* Über dem Bild, unter dem Text: dunkel von links nach rechts auslaufen */
  .final-cta__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      rgba(8, 7, 6, 0.94) 0%,
      rgba(8, 7, 6, 0.78) 28%,
      rgba(8, 7, 6, 0.42) 52%,
      rgba(8, 7, 6, 0.14) 78%,
      rgba(8, 7, 6, 0) 100%
    );
  }

  @media (max-width: 640px) {
    .final-cta__scrim {
      background: linear-gradient(
        90deg,
        rgba(8, 7, 6, 0.92) 0%,
        rgba(8, 7, 6, 0.75) 35%,
        rgba(8, 7, 6, 0.5) 65%,
        rgba(8, 7, 6, 0.35) 100%
      );
    }
  }

  .final-cta__inner {
    position: relative;
    z-index: 2;
    text-align: left;
    max-width: 38rem;
    padding-block: var(--space-lg);
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
  }

  .final-cta__eyebrow {
    margin: 0 0 var(--space-sm);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(250, 248, 245, 0.72);
  }

  .final-cta__title {
    margin: 0;
    color: #faf8f5;
  }

  .final-cta__lead {
    margin: var(--space-md) 0 var(--space-lg);
    max-width: 36rem;
    color: rgba(247, 245, 242, 0.92);
    font-size: 1.08rem;
    line-height: 1.65;
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.35);
  }

  .final-cta__actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .final-cta__hint {
    margin: 0;
    font-size: 0.8rem;
    color: rgba(247, 245, 242, 0.65);
    max-width: 32rem;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.35);
  }
</style>
