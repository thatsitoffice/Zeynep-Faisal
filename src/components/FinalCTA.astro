---
import BookingButton from "./BookingButton.astro";
import { SITE } from "../data/site";
import { GOOGLE } from "../data/google";
import { SALON_IMAGES } from "../data/salon-images";

const bg = SALON_IMAGES.cta;

const mapsPlaceHref = `https://www.google.com/maps?cid=${GOOGLE.mapsCid}&hl=de`;
const mapsDirectionsHref =
  "https://www.google.com/maps/dir/?api=1&destination=" +
  encodeURIComponent("Cranger Str. 316, 45891 Gelsenkirchen");
/** Klassisches Google-Embed (ohne API-Key) — zeigt die Adresse zentriert */
const mapEmbedSrc =
  "https://maps.google.com/maps?q=" +
  encodeURIComponent("Cranger Str. 316, 45891 Gelsenkirchen") +
  "&hl=de&z=16&output=embed";
---

<section class="final-cta section" aria-labelledby="final-cta-heading">
  <div class="final-cta__media" aria-hidden="true">
    <img
      src={bg.src}
      alt=""
      width={bg.w}
      height={bg.h}
      loading="lazy"
      decoding="async"
      class="final-cta__img"
    />
  </div>
  <div class="final-cta__scrim" aria-hidden="true"></div>

  <div class="final-cta__row">
    <div class="final-cta__inner" data-reveal>
      <p class="final-cta__eyebrow">Planity</p>
      <h2 id="final-cta-heading" class="final-cta__title display-lg">
        Ihr Termin — in wenigen Schritten reserviert
      </h2>
      <p class="final-cta__lead">
        Wählen Sie Leistung, Datum und Lieblingszeit. Sie sehen Verfügbarkeiten live — ohne Warteschleife, ohne Rätselraten.
        {SITE.name} freut sich darauf, Sie im Salon zu begrüßen.
      </p>
      <div class="final-cta__actions">
        <BookingButton variant="on-dark" />
        <p class="final-cta__hint">
          Link öffnet die offizielle Planity-Seite für unseren Meisterbetrieb in {SITE.city}.
        </p>
      </div>
    </div>

    <aside class="final-cta__map-card card" data-reveal aria-labelledby="final-cta-map-heading">
      <h3 id="final-cta-map-heading" class="final-cta__map-title">Standort</h3>
      <address class="final-cta__address">
        {SITE.name}<br />
        <span class="final-cta__address-line">{SITE.addressLine}</span>
      </address>
      <div class="final-cta__map-frame">
        <iframe
          title="Karte: Salon in Gelsenkirchen"
          src={mapEmbedSrc}
          class="final-cta__map-iframe"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        />
      </div>
      <div class="final-cta__map-links">
        <a class="final-cta__map-link" href={mapsDirectionsHref} target="_blank" rel="noopener noreferrer">
          Route planen <span aria-hidden="true">↗</span>
        </a>
        <a class="final-cta__map-link final-cta__map-link--muted" href={mapsPlaceHref} target="_blank" rel="noopener noreferrer">
          Google Maps Profil <span aria-hidden="true">↗</span>
        </a>
      </div>
    </aside>
  </div>
</section>

<style>
  .final-cta {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-xl);
    padding-inline: 0;
    color: #faf8f5;
    box-sizing: border-box;
  }

  @media (min-width: 768px) {
    .final-cta {
      padding-block: var(--space-2xl);
    }
  }

  .final-cta__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .final-cta__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 45%;
    filter: saturate(1.05) brightness(0.92);
  }

  /* Über dem Bild, unter dem Text: dunkel von links nach rechts auslaufen */
  .final-cta__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      rgba(8, 7, 6, 0.94) 0%,
      rgba(8, 7, 6, 0.78) 28%,
      rgba(8, 7, 6, 0.42) 52%,
      rgba(8, 7, 6, 0.14) 78%,
      rgba(8, 7, 6, 0) 100%
    );
  }

  @media (max-width: 640px) {
    .final-cta__scrim {
      background: linear-gradient(
        90deg,
        rgba(8, 7, 6, 0.92) 0%,
        rgba(8, 7, 6, 0.75) 35%,
        rgba(8, 7, 6, 0.5) 65%,
        rgba(8, 7, 6, 0.35) 100%
      );
    }
  }

  .final-cta__row {
    position: relative;
    z-index: 2;
    display: grid;
    gap: var(--space-lg);
    align-items: stretch;
    padding-inline: max(var(--page-pad), env(safe-area-inset-left, 0px))
      max(var(--page-pad), env(safe-area-inset-right, 0px));
    padding-block: var(--space-md);
    padding-bottom: max(var(--space-md), env(safe-area-inset-bottom, 0px));
    box-sizing: border-box;
  }

  @media (min-width: 900px) {
    .final-cta__row {
      grid-template-columns: minmax(0, 1fr) minmax(260px, min(38vw, 400px));
      gap: var(--space-xl);
      align-items: center;
      max-width: 120rem;
      margin-inline: auto;
      padding-block: var(--space-lg);
      padding-bottom: max(var(--space-lg), env(safe-area-inset-bottom, 0px));
      padding-inline: max(clamp(var(--page-pad), 4vw, 2.5rem), env(safe-area-inset-left, 0px))
        max(clamp(var(--page-pad), 4vw, 2.5rem), env(safe-area-inset-right, 0px));
      padding-left: max(clamp(var(--page-pad), 10vw, 6rem), env(safe-area-inset-left, 0px));
    }
  }

  .final-cta__inner {
    text-align: left;
    width: 100%;
    max-width: 36rem;
    margin-inline: 0;
    padding-block: 0;
    box-sizing: border-box;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
  }

  @media (min-width: 900px) {
    .final-cta__inner {
      max-width: min(30rem, 100%);
      justify-self: start;
    }
  }

  .final-cta__map-card {
    color: var(--color-ink);
    text-shadow: none;
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-line);
  }

  .final-cta__map-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .final-cta__address {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.55;
    font-style: normal;
    color: var(--color-ink-muted);
  }

  .final-cta__address-line {
    color: var(--color-ink);
    font-weight: 500;
  }

  .final-cta__map-frame {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--color-line);
    min-height: 176px;
  }

  .final-cta__map-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .final-cta__map-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin-top: 0.15rem;
  }

  .final-cta__map-link {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }

  .final-cta__map-link:hover {
    text-decoration: underline;
  }

  .final-cta__map-link--muted {
    font-weight: 500;
    color: var(--color-ink-muted);
  }

  .final-cta__eyebrow {
    margin: 0 0 var(--space-sm);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(250, 248, 245, 0.72);
  }

  .final-cta__title {
    margin: 0;
    color: #faf8f5;
  }

  .final-cta__lead {
    margin: var(--space-md) 0 var(--space-lg);
    max-width: none;
    color: rgba(247, 245, 242, 0.92);
    font-size: 1.08rem;
    line-height: 1.65;
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.35);
  }

  .final-cta__actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .final-cta__hint {
    margin: 0;
    font-size: 0.8rem;
    color: rgba(247, 245, 242, 0.65);
    max-width: none;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.35);
  }
</style>
