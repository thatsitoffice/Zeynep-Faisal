---
import BookingButton from "./BookingButton.astro";
import { SITE } from "../data/site";

interface Props {
  variant?: "default" | "overlay";
  heroTone?: "dark" | "light";
}

const { variant = "default", heroTone = "dark" } = Astro.props;
const isOverlay = variant === "overlay";
const isOverlayLight = isOverlay && heroTone === "light";
const isOverlayDark = isOverlay && !isOverlayLight;

const bookingVariant = isOverlayDark ? "heroOutline" : "primary";
const mobileBtnClass = isOverlayDark ? "btn--hero-outline" : "btn--primary";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isHome = path === "/";
const toSection = (fragment: string) => (isHome ? `#${fragment}` : `/#${fragment}`);

const navLeft = [
  { href: "/", label: "Home" },
  { href: toSection("vertrauen"), label: "Vorteile" },
  { href: "/preise/", label: "Preise" },
];

const navRight = [
  { href: toSection("produkte"), label: "Produkte" },
  { href: toSection("stimmung"), label: "Atmosphäre" },
  { href: toSection("stimmen"), label: "Stimmen" },
];

const logoAlt = `${SITE.name} — ${SITE.tagline}, Startseite`;
---

<header
  class:list={[
    "site-header",
    isOverlay && "site-header--overlay",
    isOverlayLight && "site-header--overlay-light",
  ]}
  id="site-header"
  data-overlay={isOverlay ? "true" : undefined}
  data-hero-tone={isOverlay ? heroTone : undefined}
>
  <div class="site-header__inner container">
    <nav class="site-header__nav-main" aria-label="Hauptnavigation">
      <ul class="site-header__links site-header__links--start">
        {
          navLeft.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>

      <a class="site-header__logo" href="/" aria-label={logoAlt}>
        <img
          src="/logo-zeynep-faisal.png"
          alt=""
          width="220"
          height="72"
          class="site-header__logo-img"
          decoding="async"
        />
      </a>

      <ul class="site-header__links site-header__links--end">
        {
          navRight.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-header__cta-cell">
      <div class="site-header__cta">
        <BookingButton variant={bookingVariant} />
      </div>
      <a
        class:list={["site-header__cta-mobile", "btn", mobileBtnClass]}
        href={SITE.bookingUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Termin buchen (Planity)"
      >
        Buchen
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(244, 241, 235, 0.82);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    border-bottom: 1px solid rgba(20, 19, 18, 0.05);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.65) inset;
    transition:
      background 0.45s var(--ease-luxe),
      border-color 0.45s ease,
      box-shadow 0.45s ease;
  }

  .site-header--overlay {
    position: fixed;
    left: 0;
    right: 0;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: none;
  }

  .site-header--overlay.site-header--overlay-light:not(.site-header--scrolled) {
    border-bottom-color: rgba(45, 33, 24, 0.08);
  }

  .site-header--overlay.site-header--scrolled {
    background: rgba(244, 241, 235, 0.92);
    backdrop-filter: blur(18px) saturate(1.15);
    -webkit-backdrop-filter: blur(18px) saturate(1.15);
    border-bottom: 1px solid rgba(20, 19, 18, 0.06);
    box-shadow: 0 8px 32px -20px rgba(20, 19, 18, 0.12);
  }

  .site-header__inner {
    position: relative;
    min-height: 4.5rem;
    padding-block: var(--space-sm);
  }

  @media (min-width: 1024px) {
    .site-header__inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr auto;
      align-items: center;
      gap: clamp(0.75rem, 2vw, 1.25rem);
    }

    .site-header__nav-main {
      display: contents;
    }

    .site-header__links--start {
      grid-column: 1;
      justify-self: start;
    }

    .site-header__logo {
      grid-column: 2;
      justify-self: center;
    }

    .site-header__links--end {
      grid-column: 3;
      justify-self: end;
    }

    .site-header__cta-cell {
      grid-column: 4;
      justify-self: end;
    }
  }

  @media (max-width: 1023px) {
    .site-header__inner {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-sm);
      padding-top: var(--space-xs);
    }

    .site-header__cta-cell {
      position: absolute;
      top: var(--space-sm);
      right: 0;
      z-index: 2;
    }

    .site-header__nav-main {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-sm);
      padding-right: 5.5rem;
      padding-top: 0.25rem;
    }

    .site-header__logo {
      order: -1;
      margin-inline: auto;
      margin-bottom: 0.15rem;
    }

    .site-header__links--start,
    .site-header__links--end {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.35rem 0.85rem;
    }
  }

  .site-header__links {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  @media (min-width: 1024px) {
    .site-header__links {
      display: flex;
      flex-wrap: wrap;
      gap: clamp(0.65rem, 1.5vw, 1.15rem);
      align-items: center;
    }
  }

  .site-header__links a {
    text-decoration: none;
    color: var(--color-ink);
    transition: color 0.3s ease;
  }

  .site-header__links a:hover {
    color: var(--color-accent);
  }

  .site-header--overlay:not(.site-header--overlay-light):not(.site-header--scrolled) .site-header__links a {
    color: rgba(255, 255, 255, 0.9);
  }

  .site-header--overlay:not(.site-header--overlay-light):not(.site-header--scrolled) .site-header__links a:hover {
    color: #fff;
  }

  .site-header--overlay.site-header--scrolled .site-header__links a {
    color: var(--color-ink);
  }

  .site-header__logo {
    flex-shrink: 0;
    line-height: 0;
    text-decoration: none;
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease;
  }

  .site-header__logo:hover {
    text-decoration: none;
    transform: scale(1.02);
  }

  .site-header__logo-img {
    height: clamp(2.25rem, 5vw, 2.65rem);
    width: auto;
    max-width: min(200px, 52vw);
    object-fit: contain;
    display: block;
  }

  /* Dunkles Hero: Logo auf hellem Chip lesbar */
  .site-header--overlay:not(.site-header--overlay-light):not(.site-header--scrolled) .site-header__logo {
    padding: 0.28rem 0.55rem;
    background: rgba(255, 252, 250, 0.94);
    border-radius: 12px;
    box-shadow: 0 6px 24px -8px rgba(0, 0, 0, 0.25);
  }

  .site-header--overlay.site-header--scrolled .site-header__logo {
    padding: 0;
    background: transparent;
    box-shadow: none;
    border-radius: 0;
  }

  .site-header__cta-cell {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .site-header__cta {
    display: none;
  }

  @media (min-width: 1024px) {
    .site-header__cta {
      display: block;
    }
  }

  .site-header__cta-mobile {
    padding-inline: 1rem;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
  }

  @media (min-width: 1024px) {
    .site-header__cta-mobile {
      display: none;
    }
  }

  .site-header--overlay.site-header--scrolled .site-header__cta :global(.btn--hero-outline) {
    background: var(--color-ink);
    color: #faf8f5;
    border-color: var(--color-ink);
    box-shadow: 0 10px 28px -12px rgba(20, 19, 18, 0.35);
  }

  .site-header--overlay.site-header--scrolled .site-header__cta :global(.btn--hero-outline:hover) {
    background: var(--color-deep);
    border-color: var(--color-deep);
  }

  .site-header--overlay.site-header--scrolled .site-header__cta-mobile.btn--hero-outline {
    background: var(--color-ink);
    color: #faf8f5;
    border-color: var(--color-ink);
  }

  .site-header--overlay.site-header--scrolled .site-header__cta-mobile.btn--hero-outline:hover {
    background: var(--color-deep);
  }
</style>
