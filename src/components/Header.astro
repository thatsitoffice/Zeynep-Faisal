---
import BookingButton from "./BookingButton.astro";
import { SITE } from "../data/site";

interface Props {
  /** Start: transparent über Hero (Startseite). Sonst klassische helle Leiste. */
  variant?: "default" | "overlay";
}

const { variant = "default" } = Astro.props;
const isOverlay = variant === "overlay";

const nav = [
  { href: "#leistungen", label: "Leistungen" },
  { href: "/preise/", label: "Preise" },
  { href: "#produkte", label: "Produkte" },
  { href: "#ueber-uns", label: "Über uns" },
  { href: "#stimmen", label: "Stimmen" },
];
---

<header
  class:list={["site-header", isOverlay && "site-header--overlay"]}
  id="site-header"
  data-overlay={isOverlay ? "true" : undefined}
>
  <div class="site-header__inner container">
    <a class="site-header__brand" href="/" aria-label={`${SITE.name} — Start`}>
      <span class="site-header__name">{SITE.name}</span>
      <span class="site-header__tag">{SITE.tagline}</span>
    </a>

    <nav class="site-header__nav" aria-label="Hauptnavigation">
      <ul class="site-header__list">
        {
          nav.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-header__cta">
      <BookingButton variant={isOverlay ? "heroOutline" : "primary"} />
    </div>

    <a
      class:list={["site-header__cta-mobile", "btn", isOverlay ? "btn--hero-outline" : "btn--primary"]}
      href={SITE.bookingUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Termin buchen (Planity)"
    >
      Buchen
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(244, 241, 235, 0.82);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    border-bottom: 1px solid rgba(20, 19, 18, 0.05);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.65) inset;
    transition:
      background 0.45s var(--ease-luxe),
      border-color 0.45s ease,
      box-shadow 0.45s ease;
  }

  /* Transparent über Hero — editorial wie Kalm-inspirierte Sites */
  .site-header--overlay {
    position: fixed;
    left: 0;
    right: 0;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: none;
  }

  .site-header--overlay.site-header--scrolled {
    background: rgba(244, 241, 235, 0.92);
    backdrop-filter: blur(18px) saturate(1.15);
    -webkit-backdrop-filter: blur(18px) saturate(1.15);
    border-bottom: 1px solid rgba(20, 19, 18, 0.06);
    box-shadow: 0 8px 32px -20px rgba(20, 19, 18, 0.12);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    min-height: var(--header-h);
    padding-block: var(--space-sm);
  }

  .site-header__brand {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    text-decoration: none;
    min-width: 0;
    transition: color 0.35s ease;
  }

  .site-header__brand:hover {
    text-decoration: none;
  }

  .site-header__name {
    font-family: var(--font-display);
    font-size: 1.12rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.15;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--color-ink);
    transition: color 0.35s ease;
  }

  .site-header__tag {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
    transition: color 0.35s ease;
  }

  .site-header--overlay:not(.site-header--scrolled) .site-header__name {
    color: rgba(255, 255, 255, 0.96);
  }

  .site-header--overlay:not(.site-header--scrolled) .site-header__tag {
    color: rgba(255, 255, 255, 0.55);
  }

  .site-header--overlay.site-header--scrolled .site-header__name {
    color: var(--color-ink);
  }

  .site-header--overlay.site-header--scrolled .site-header__tag {
    color: var(--color-accent);
  }

  .site-header__nav {
    display: none;
  }

  @media (min-width: 900px) {
    .site-header__nav {
      display: block;
    }
  }

  .site-header__list {
    display: flex;
    gap: clamp(1rem, 2.5vw, 1.75rem);
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .site-header__list a {
    text-decoration: none;
    color: var(--color-ink);
    transition: color 0.3s ease;
  }

  .site-header__list a:hover {
    color: var(--color-accent);
  }

  .site-header--overlay:not(.site-header--scrolled) .site-header__list a {
    color: rgba(255, 255, 255, 0.88);
  }

  .site-header--overlay:not(.site-header--scrolled) .site-header__list a:hover {
    color: #fff;
  }

  .site-header--overlay.site-header--scrolled .site-header__list a {
    color: var(--color-ink);
  }

  .site-header__cta {
    display: none;
  }

  @media (min-width: 900px) {
    .site-header__cta {
      display: block;
      flex-shrink: 0;
    }
  }

  .site-header__cta-mobile {
    padding-inline: 1rem;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
  }

  @media (min-width: 900px) {
    .site-header__cta-mobile {
      display: none;
    }
  }

  /* Nach dem Hero: Buchungsbutton wie Primary (auf heller Leiste lesbar) */
  .site-header--overlay.site-header--scrolled .site-header__cta :global(.btn--hero-outline) {
    background: var(--color-ink);
    color: #faf8f5;
    border-color: var(--color-ink);
    box-shadow: 0 10px 28px -12px rgba(20, 19, 18, 0.35);
  }

  .site-header--overlay.site-header--scrolled .site-header__cta :global(.btn--hero-outline:hover) {
    background: var(--color-deep);
    border-color: var(--color-deep);
  }

  .site-header--overlay.site-header--scrolled.site-header--overlay .site-header__cta-mobile.btn--hero-outline {
    background: var(--color-ink);
    color: #faf8f5;
    border-color: var(--color-ink);
  }

  .site-header--overlay.site-header--scrolled .site-header__cta-mobile.btn--hero-outline:hover {
    background: var(--color-deep);
  }
</style>
