---
/**
 * Startseite: Kernleistungen mit Preisen (Planity) + CTAs
 */
import SectionHeading from "./SectionHeading.astro";
import BookingButton from "./BookingButton.astro";
import { PLANITY_PRICING_URL, PRICE_PREVIEW_BLOCKS } from "../data/pricing";
---

<section class="section pricing-preview" id="preise" aria-labelledby="pricing-preview-heading">
  <div class="container">
    <SectionHeading
      eyebrow="Preise"
      title="Häufig gebuchte Leistungen — mit Planity-Preisen"
      subtitle="Auszug der regulären Services inklusive Dauer und Preis. Erweiterungen, Balayage, Pflegepakete und alle weiteren Positionen finden Sie vollständig bei Planity und auf unserer Preisseite."
      headingId="pricing-preview-heading"
    />

    <p class="pricing-preview__source muted">
      Quelle & Buchung:{" "}
      <a href={PLANITY_PRICING_URL} target="_blank" rel="noopener noreferrer">
        Planity-Profil Gelsenkirchen
      </a>
      {" "}— bei Abweichungen gilt der Eintrag dort. „Ab“-Preise je nach Aufwand.
    </p>

    <div class="pricing-preview__layout">
      <div class="pricing-preview__card card" data-reveal>
        <div class="pricing-preview__card-head">
          <h3 class="pricing-preview__card-title">Auszug aus dem Katalog</h3>
          <p class="pricing-preview__card-sub muted">
            Endpreis in der Terminwahl wie bei Planity — individuelle Beratung im Salon.
          </p>
        </div>
        {
          PRICE_PREVIEW_BLOCKS.map((block, bi) => (
            <div class:list={["pricing-preview__group", bi > 0 && "pricing-preview__group--sep"]}>
              <h4 class="pricing-preview__group-title">{block.title}</h4>
              <ul class="pricing-preview__list" role="list">
                {block.rows.map((item) => (
                  <li class="pricing-preview__item">
                    <div class="pricing-preview__item-copy">
                      {item.badge && <span class="pricing-preview__badge">{item.badge}</span>}
                      <span class="pricing-preview__name">{item.name}</span>
                      {item.duration && <span class="pricing-preview__dur muted">{item.duration}</span>}
                    </div>
                    <span class="pricing-preview__price">{item.price}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <aside class="pricing-preview__aside" data-reveal>
        <div class="pricing-preview__cta-card card">
          <p class="pricing-preview__cta-label">Planity</p>
          <h3 class="pricing-preview__cta-title">Termin oder komplette Liste</h3>
          <p class="pricing-preview__cta-text muted">
            Freie Slots und alle Services in Echtzeit — oder zuerst unsere Preisseite mit allen Kategorien durchstöbern.
          </p>
          <div class="pricing-preview__cta-row">
            <BookingButton />
            <a class="btn btn--ghost" href="/preise/">Komplette Preisliste</a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .pricing-preview__source {
    margin: calc(-1 * var(--space-sm)) 0 var(--space-lg);
    max-width: 44rem;
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .pricing-preview__source a {
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }

  .pricing-preview__source a:hover {
    text-decoration: underline;
  }

  .pricing-preview__group-title {
    margin: 0 0 var(--space-sm);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  .pricing-preview__group--sep {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-line);
  }

  .pricing-preview__layout {
    display: grid;
    gap: var(--space-lg);
    align-items: stretch;
  }

  @media (min-width: 960px) {
    .pricing-preview__layout {
      grid-template-columns: 1.15fr 0.9fr;
    }
  }

  .pricing-preview__card {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg);
  }

  .pricing-preview__card-head {
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-line);
  }

  .pricing-preview__card-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .pricing-preview__card-sub {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .pricing-preview__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pricing-preview__item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-line);
  }

  .pricing-preview__item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .pricing-preview__item-copy {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .pricing-preview__badge {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .pricing-preview__name {
    font-weight: 600;
    font-size: 1.02rem;
    line-height: 1.35;
    color: var(--color-ink);
  }

  .pricing-preview__dur {
    font-size: 0.84rem;
    line-height: 1.45;
  }

  .pricing-preview__price {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    font-size: 1.05rem;
    flex-shrink: 0;
    color: var(--color-ink);
  }

  .pricing-preview__aside {
    display: flex;
  }

  .pricing-preview__cta-card {
    width: 100%;
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-sm);
  }

  .pricing-preview__cta-label {
    margin: 0;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .pricing-preview__cta-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .pricing-preview__cta-text {
    margin: 0 0 var(--space-sm);
    font-size: 0.94rem;
    line-height: 1.58;
    flex: 1;
  }

  .pricing-preview__cta-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: auto;
    padding-top: var(--space-sm);
  }

  .pricing-preview__cta-row :global(.btn) {
    width: 100%;
    justify-content: center;
    min-height: 3rem;
  }

  @media (min-width: 480px) {
    .pricing-preview__cta-row :global(.btn) {
      width: auto;
      align-self: flex-start;
    }
  }
</style>
