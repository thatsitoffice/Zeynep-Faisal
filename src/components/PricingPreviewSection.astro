---
/**
 * Startseite: Intro + CTA, Hauptgruppen-Kacheln (Anker /preise/), Katalogauszug
 */
import SectionHeading from "./SectionHeading.astro";
import BookingButton from "./BookingButton.astro";
import {
  PLANITY_PRICING_URL,
  PRICE_MAIN_GROUP_TILES,
  PRICE_PREVIEW_BLOCKS,
} from "../data/pricing";
---

<section class="section pricing-preview" id="preise" aria-labelledby="pricing-preview-heading">
  <div class="container">
    <div class="pricing-preview__intro-row">
      <div class="pricing-preview__intro-copy">
        <SectionHeading
          eyebrow="Preise"
          title="Häufig gebuchte Leistungen — mit Planity-Preisen"
          subtitle="Auszug der regulären Services inklusive Dauer und Preis. Erweiterungen, Balayage, Pflegepakete und alle weiteren Positionen finden Sie vollständig bei Planity und auf unserer Preisseite."
          headingId="pricing-preview-heading"
        />

        <p class="pricing-preview__source muted">
          Quelle & Buchung:{" "}
          <a href={PLANITY_PRICING_URL} target="_blank" rel="noopener noreferrer">
            Planity-Profil Gelsenkirchen
          </a>
          {" "}— bei Abweichungen gilt der Eintrag dort. „Ab“-Preise je nach Aufwand.
        </p>
      </div>

      <aside class="pricing-preview__cta-aside" data-reveal aria-label="Termin und Preisliste">
        <div class="pricing-preview__cta-card card">
          <p class="pricing-preview__cta-label">Planity</p>
          <h3 class="pricing-preview__cta-title">Termin oder komplette Liste</h3>
          <p class="pricing-preview__cta-text muted">
            Freie Slots und alle Services in Echtzeit — oder zuerst die Preisseite mit allen Kategorien.
          </p>
          <div class="pricing-preview__cta-row">
            <BookingButton />
            <a class="btn btn--ghost" href="/preise/">Komplette Preisliste</a>
          </div>
        </div>
      </aside>
    </div>

    <nav class="pricing-preview__tiles" aria-label="Hauptgruppen der Preisliste">
      {
        PRICE_MAIN_GROUP_TILES.map((tile) => (
          <a
            class="pricing-preview__tile card"
            href={`/preise/#${tile.anchorId}`}
            data-reveal
          >
            <span class="pricing-preview__tile-title">{tile.title}</span>
            <span class="pricing-preview__tile-blurb">{tile.blurb}</span>
            <span class="pricing-preview__tile-cta">
              Zur Sektion auf der Preisseite
              <span class="pricing-preview__tile-arrow" aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </nav>

    <div class="pricing-preview__catalog card" data-reveal>
      <div class="pricing-preview__card-head">
        <h3 class="pricing-preview__card-title">Auszug aus dem Katalog</h3>
        <p class="pricing-preview__card-sub muted">
          Endpreis in der Terminwahl wie bei Planity — individuelle Beratung im Salon.
        </p>
      </div>
      {
        PRICE_PREVIEW_BLOCKS.map((block, bi) => (
          <div class:list={["pricing-preview__group", bi > 0 && "pricing-preview__group--sep"]}>
            <h4 class="pricing-preview__group-title">{block.title}</h4>
            <ul class="pricing-preview__list" role="list">
              {block.rows.map((item) => (
                <li class="pricing-preview__item">
                  <div class="pricing-preview__item-copy">
                    {item.badge && <span class="pricing-preview__badge">{item.badge}</span>}
                    <span class="pricing-preview__name">{item.name}</span>
                    {item.duration && <span class="pricing-preview__dur muted">{item.duration}</span>}
                  </div>
                  <span class="pricing-preview__price">{item.price}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .pricing-preview__intro-row {
    display: grid;
    gap: var(--space-lg);
    align-items: start;
    margin-bottom: var(--space-xl);
  }

  @media (min-width: 900px) {
    .pricing-preview__intro-row {
      grid-template-columns: minmax(0, 1fr) minmax(15.5rem, 20rem);
      gap: var(--space-xl);
    }
  }

  .pricing-preview__intro-copy {
    min-width: 0;
  }

  .pricing-preview__intro-copy :global(.section-heading) {
    margin-bottom: var(--space-md);
  }

  .pricing-preview__source {
    margin: 0;
    max-width: 44rem;
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .pricing-preview__source a {
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }

  .pricing-preview__source a:hover {
    text-decoration: underline;
  }

  .pricing-preview__cta-aside {
    display: flex;
    width: 100%;
  }

  @media (min-width: 900px) {
    .pricing-preview__cta-aside {
      position: sticky;
      top: calc(var(--header-h) + var(--space-md));
    }
  }

  .pricing-preview__cta-card {
    width: 100%;
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-sm);
  }

  .pricing-preview__cta-label {
    margin: 0;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .pricing-preview__cta-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.2vw, 1.45rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .pricing-preview__cta-text {
    margin: 0 0 var(--space-sm);
    font-size: 0.92rem;
    line-height: 1.55;
    flex: 1;
  }

  .pricing-preview__cta-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: auto;
    padding-top: var(--space-sm);
  }

  .pricing-preview__cta-row :global(.btn) {
    width: 100%;
    justify-content: center;
    min-height: 3rem;
  }

  @media (min-width: 480px) {
    .pricing-preview__cta-row :global(.btn) {
      width: auto;
      align-self: flex-start;
    }
  }

  .pricing-preview__tiles {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  @media (min-width: 700px) {
    .pricing-preview__tiles {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pricing-preview__tile {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
    margin: 0;
    padding: var(--space-md) var(--space-lg);
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-line);
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }

  .pricing-preview__tile:hover {
    border-color: rgba(20, 19, 18, 0.14);
    box-shadow: 0 12px 36px -18px rgba(20, 19, 18, 0.18);
    transform: translateY(-2px);
  }

  .pricing-preview__tile:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .pricing-preview__tile-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-ink);
  }

  .pricing-preview__tile-blurb {
    font-size: 0.86rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    flex: 1;
  }

  .pricing-preview__tile-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.15rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .pricing-preview__tile-arrow {
    transition: transform 0.2s ease;
  }

  .pricing-preview__tile:hover .pricing-preview__tile-arrow {
    transform: translateX(3px);
  }

  .pricing-preview__catalog {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg);
  }

  .pricing-preview__group-title {
    margin: 0 0 var(--space-sm);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  .pricing-preview__group--sep {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-line);
  }

  .pricing-preview__card-head {
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-line);
  }

  .pricing-preview__card-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .pricing-preview__card-sub {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .pricing-preview__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pricing-preview__item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-line);
  }

  .pricing-preview__item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .pricing-preview__item-copy {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .pricing-preview__badge {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .pricing-preview__name {
    font-weight: 600;
    font-size: 1.02rem;
    line-height: 1.35;
    color: var(--color-ink);
  }

  .pricing-preview__dur {
    font-size: 0.84rem;
    line-height: 1.45;
  }

  .pricing-preview__price {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    font-size: 1.05rem;
    flex-shrink: 0;
    color: var(--color-ink);
  }

  @media (prefers-reduced-motion: reduce) {
    .pricing-preview__tile,
    .pricing-preview__tile-arrow {
      transition: none;
    }

    .pricing-preview__tile:hover {
      transform: none;
    }
  }
</style>
