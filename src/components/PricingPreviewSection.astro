---
/**
 * Startseite: übersichtliche Preis-Vorschau + genau 2 CTAs
 */
import SectionHeading from "./SectionHeading.astro";
import BookingButton from "./BookingButton.astro";
import { PRICE_PREVIEW_HIGHLIGHTS } from "../data/pricing";
---

<section class="section pricing-preview" id="preise" aria-labelledby="pricing-preview-heading">
  <div class="container">
    <SectionHeading
      eyebrow="Preise"
      title="Transparent — wie in Planity gebucht"
      subtitle="Vier beliebte Einstiege als Orientierung. Alle Zeiten, Pakete und Sonderleistungen finden Sie auf der Preisseite — buchen können Sie direkt bei Planity."
      headingId="pricing-preview-heading"
    />

    <div class="pricing-preview__layout">
      <div class="pricing-preview__card card" data-reveal>
        <div class="pricing-preview__card-head">
          <h3 class="pricing-preview__card-title">Unsere beliebtesten Leistungen</h3>
          <p class="pricing-preview__card-sub muted">
            Endpreis je nach Aufwand und Haarlänge — wie in der Beratung vereinbart.
          </p>
        </div>
        <ul class="pricing-preview__list" role="list">
          {
            PRICE_PREVIEW_HIGHLIGHTS.map((item) => (
              <li class="pricing-preview__item">
                <div class="pricing-preview__item-copy">
                  {item.badge && <span class="pricing-preview__badge">{item.badge}</span>}
                  <span class="pricing-preview__name">{item.name}</span>
                  {item.duration && <span class="pricing-preview__dur muted">{item.duration}</span>}
                </div>
                <span class="pricing-preview__price">{item.price}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <aside class="pricing-preview__aside" data-reveal>
        <div class="pricing-preview__cta-card card">
          <p class="pricing-preview__cta-label">Planity</p>
          <h3 class="pricing-preview__cta-title">Termin oder komplette Liste</h3>
          <p class="pricing-preview__cta-text muted">
            Freie Slots und alle Services in Echtzeit — oder zuerst unsere Preisseite mit allen Kategorien durchstöbern.
          </p>
          <div class="pricing-preview__cta-row">
            <BookingButton />
            <a class="btn btn--ghost" href="/preise/">Komplette Preisliste</a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .pricing-preview__layout {
    display: grid;
    gap: var(--space-lg);
    align-items: stretch;
  }

  @media (min-width: 960px) {
    .pricing-preview__layout {
      grid-template-columns: 1.15fr 0.9fr;
    }
  }

  .pricing-preview__card {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg);
  }

  .pricing-preview__card-head {
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-line);
  }

  .pricing-preview__card-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .pricing-preview__card-sub {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .pricing-preview__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pricing-preview__item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-line);
  }

  .pricing-preview__item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .pricing-preview__item-copy {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .pricing-preview__badge {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .pricing-preview__name {
    font-weight: 600;
    font-size: 1.02rem;
    line-height: 1.35;
    color: var(--color-ink);
  }

  .pricing-preview__dur {
    font-size: 0.84rem;
    line-height: 1.45;
  }

  .pricing-preview__price {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    font-size: 1.05rem;
    flex-shrink: 0;
    color: var(--color-ink);
  }

  .pricing-preview__aside {
    display: flex;
  }

  .pricing-preview__cta-card {
    width: 100%;
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-sm);
  }

  .pricing-preview__cta-label {
    margin: 0;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .pricing-preview__cta-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .pricing-preview__cta-text {
    margin: 0 0 var(--space-sm);
    font-size: 0.94rem;
    line-height: 1.58;
    flex: 1;
  }

  .pricing-preview__cta-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: auto;
    padding-top: var(--space-sm);
  }

  .pricing-preview__cta-row :global(.btn) {
    width: 100%;
    justify-content: center;
    min-height: 3rem;
  }

  @media (min-width: 480px) {
    .pricing-preview__cta-row :global(.btn) {
      width: auto;
      align-self: flex-start;
    }
  }
</style>
