---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  dark?: boolean;
  /** Für aria-labelledby der Sektion */
  headingId?: string;
}

const { eyebrow, title, subtitle, align = "left", dark = false, headingId } = Astro.props;
---

<header
  class:list={["section-heading", align === "center" && "section-heading--center"]}
  data-reveal
>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 id={headingId} class:list={["display-lg", dark && "section-heading__title--on-dark"]}>{title}</h2>
  {subtitle && <p class:list={["lead", "section-heading__sub", dark && "muted"]}>{subtitle}</p>}
</header>

<style>
  .section-heading {
    position: relative;
    margin-bottom: var(--space-xl);
    max-width: 40rem;
    padding-left: 1.15rem;
  }

  .section-heading::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.2rem;
    bottom: 0.35rem;
    width: 2px;
    border-radius: 2px;
    background: linear-gradient(185deg, var(--color-star) 0%, var(--color-accent) 55%, transparent 100%);
    opacity: 0.7;
  }

  .section-heading--center {
    margin-inline: auto;
    text-align: center;
    max-width: 44rem;
    padding-left: 0;
  }

  .section-heading--center::before {
    display: none;
  }

  .section-heading--center .lead {
    margin-inline: auto;
  }

  .section-heading__sub {
    margin-top: var(--space-md);
    margin-bottom: 0;
  }

  .section-heading__title--on-dark {
    color: var(--color-bg);
  }
</style>
