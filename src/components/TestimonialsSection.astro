---
import SectionHeading from "./SectionHeading.astro";
import BookingButton from "./BookingButton.astro";
import GoogleReviewsWidget from "./GoogleReviewsWidget.astro";
---

<section class="section testimonials section--tight testimonials--premium" id="stimmen" aria-labelledby="testimonials-heading">
  <div class="testimonials__watermark" aria-hidden="true">Stimmen</div>
  <div class="container testimonials__inner">
    <SectionHeading
      eyebrow="Stimmen"
      title="Was Gäste über uns sagen"
      subtitle="Echte Rückmeldungen von Google — mit direktem Link zu allen Bewertungen Ihres Profils."
      align="center"
      headingId="testimonials-heading"
    />

    <GoogleReviewsWidget />

    <div class="testimonials__cta" data-reveal>
      <BookingButton />
    </div>
  </div>
</section>

<style>
  .testimonials--premium {
    position: relative;
    overflow: hidden;
  }

  .testimonials__watermark {
    position: absolute;
    left: 50%;
    top: 0.5rem;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-size: clamp(4rem, 18vw, 12rem);
    font-weight: 400;
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: var(--color-editorial);
    opacity: 0.045;
    pointer-events: none;
    white-space: nowrap;
    z-index: 0;
  }

  .testimonials__inner {
    position: relative;
    z-index: 1;
  }

  .testimonials__cta {
    margin-top: var(--space-xl);
    display: flex;
    justify-content: center;
  }
</style>
