---
import SectionHeading from "./SectionHeading.astro";
import BookingButton from "./BookingButton.astro";
import GoogleReviewsWidget from "./GoogleReviewsWidget.astro";
---

<section class="section testimonials section--tight" id="stimmen" aria-labelledby="testimonials-heading">
  <div class="container">
    <SectionHeading
      eyebrow="Stimmen"
      title="Was Gäste über uns sagen"
      subtitle="Echte Rückmeldungen von Google — mit direktem Link zu allen Bewertungen Ihres Profils."
      align="center"
      headingId="testimonials-heading"
    />

    <GoogleReviewsWidget />

    <div class="testimonials__cta" data-reveal>
      <BookingButton />
    </div>
  </div>
</section>

<style>
  .testimonials__cta {
    margin-top: var(--space-xl);
    display: flex;
    justify-content: center;
  }
</style>
