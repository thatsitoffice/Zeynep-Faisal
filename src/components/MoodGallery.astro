---
/**
 * Staggered Mood-Gallery mit Watermark-Typo (Editorial)
 */
import { SALON_IMAGES } from "../data/salon-images";

/** Panorama unter der Galerie — Styling-Stationen (gleiches Asset wie Preisseiten-Hero) */
const salonFloor = SALON_IMAGES.preiseHero;

/** Nur noch ein Mood-Bild — Produktregal-Motive (mood1/mood2) entfernt */
const shots = [
  {
    src: SALON_IMAGES.mood3.src,
    w: SALON_IMAGES.mood3.w,
    h: SALON_IMAGES.mood3.h,
    alt: "Im Salon — Details und Ruhe",
    tall: false,
  },
];
---

<section class="mood-gallery section" id="stimmung" aria-labelledby="mood-heading">
  <div class="mood-gallery__watermark" aria-hidden="true">Atmosphäre</div>
  <div class="container mood-gallery__wrap">
    <h2 id="mood-heading" class="mood-gallery__heading">Ein Ort zum Ankommen</h2>
    <p class="mood-gallery__lead muted">
      Licht, Material und Ruhe — bevor Sie Platz nehmen, spüren Sie schon: hier wird sorgsam gearbeitet.
    </p>
    <div class="mood-gallery__grid">
      {
        shots.map((s, i) => (
          <figure class="mood-gallery__fig" data-reveal style={`--reveal-delay: ${i * 90}ms`}>
            <div class="mood-gallery__frame">
              <img
                src={s.src}
                alt={s.alt}
                width={s.w}
                height={s.h}
                loading="lazy"
                decoding="async"
                class="mood-gallery__img"
              />
            </div>
          </figure>
        ))
      }
    </div>

    <figure class="mood-gallery__panorama" data-reveal>
      <div class="mood-gallery__panorama-frame">
        <img
          src={salonFloor.src}
          alt="Salon — Stylingplätze, Spiegel und ruhige Arbeitsatmosphäre"
          width={salonFloor.w}
          height={salonFloor.h}
          loading="lazy"
          decoding="async"
          class="mood-gallery__panorama-img"
        />
      </div>
    </figure>
  </div>
</section>

<style>
  .mood-gallery {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-2xl);
  }

  .mood-gallery__watermark {
    position: absolute;
    left: 0;
    right: 0;
    top: 1rem;
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 16vw, 11rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--color-editorial);
    opacity: 0.04;
    pointer-events: none;
    white-space: nowrap;
  }

  .mood-gallery__wrap {
    position: relative;
    z-index: 1;
  }

  .mood-gallery__heading {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 3.5vw, 2.35rem);
    letter-spacing: -0.02em;
    color: var(--color-editorial);
    max-width: min(42rem, 100%);
  }

  .mood-gallery__lead {
    margin: 0 0 var(--space-xl);
    max-width: min(52rem, 100%);
    font-size: 1rem;
    line-height: 1.65;
  }

  @media (min-width: 900px) {
    .mood-gallery__heading,
    .mood-gallery__lead {
      padding-right: clamp(0rem, 6vw, 4rem);
    }
  }

  .mood-gallery__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    align-items: start;
    max-width: min(36rem, 100%);
    margin-inline: auto;
  }

  .mood-gallery__fig {
    margin: 0;
  }

  .mood-gallery__frame {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    box-shadow: var(--shadow-card);
    background: var(--color-line);
  }

  .mood-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.9s var(--ease-luxe);
  }

  @media (hover: hover) {
    .mood-gallery__frame:hover .mood-gallery__img {
      transform: scale(1.03);
    }
  }

  .mood-gallery__panorama {
    margin: var(--space-xl) 0 0;
    padding: 0;
    border: none;
  }

  .mood-gallery__panorama-frame {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 2400 / 1792;
    max-height: min(72vh, 38rem);
    box-shadow: var(--shadow-card);
    background: var(--color-line);
  }

  .mood-gallery__panorama-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 62% 48%;
    display: block;
  }

  @media (max-width: 640px) {
    .mood-gallery__panorama-img {
      object-position: 58% 42%;
    }
  }
</style>
