---
/**
 * Atmosphäre: zwei Motive ziehen über den Schriftzug „Atmosphäre“ (Watermark dahinter)
 */
import { SALON_IMAGES } from "../data/salon-images";

const leftShot = {
  src: SALON_IMAGES.atmosphereReception.src,
  w: SALON_IMAGES.atmosphereReception.w,
  h: SALON_IMAGES.atmosphereReception.h,
  alt: "Salon — Empfang und Beratung",
};

const rightShot = {
  src: SALON_IMAGES.atmosphereStyling.src,
  w: SALON_IMAGES.atmosphereStyling.w,
  h: SALON_IMAGES.atmosphereStyling.h,
  alt: "Salon — Stylingplätze und Lichtstimmung",
};
---

<section class="mood-gallery section" id="stimmung" aria-labelledby="mood-heading">
  <h2 id="mood-heading" class="mood-gallery__sr-only">Atmosphäre</h2>
  <div class="mood-gallery__wrap">
    <div class="mood-gallery__watermark" aria-hidden="true">Atmosphäre</div>
    <div class="mood-gallery__dual">
      <figure class="mood-gallery__side mood-gallery__side--left" data-reveal style="--reveal-delay: 0ms">
        <div class="mood-gallery__frame mood-gallery__frame--left-wide">
          <img
            src={leftShot.src}
            alt={leftShot.alt}
            width={leftShot.w}
            height={leftShot.h}
            loading="lazy"
            decoding="async"
            class="mood-gallery__img"
          />
        </div>
      </figure>
      <figure class="mood-gallery__side mood-gallery__side--right" data-reveal style="--reveal-delay: 90ms">
        <div class="mood-gallery__frame">
          <img
            src={rightShot.src}
            alt={rightShot.alt}
            width={rightShot.w}
            height={rightShot.h}
            loading="lazy"
            decoding="async"
            class="mood-gallery__img"
          />
        </div>
      </figure>
    </div>
  </div>
</section>

<style>
  .mood-gallery {
    position: relative;
    overflow-x: clip;
    overflow-y: visible;
    padding-block: clamp(var(--space-2xl), 8vw, 5.5rem);
  }

  .mood-gallery__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /**
   * Volle Viewport-Breite wie der Seitenrand — Bilder können bis an den Rand und über die Mitte
   */
  .mood-gallery__wrap {
    position: relative;
    z-index: 0;
    isolation: isolate;
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    padding-inline: max(var(--page-pad), env(safe-area-inset-left, 0px))
      max(var(--page-pad), env(safe-area-inset-right, 0px));
    box-sizing: border-box;
  }

  /**
   * Schriftzug in der Mitte, hinter den Bildern (niedriger z-index im Stack)
   */
  .mood-gallery__watermark {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
    width: 100%;
    max-width: 100%;
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 13vw, 9.5rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-editorial);
    opacity: 0.07;
    pointer-events: none;
    white-space: nowrap;
    padding-inline: var(--page-pad);
    box-sizing: border-box;
  }

  .mood-gallery__dual {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.85fr);
    gap: 0;
    align-items: center;
    min-height: min(56vw, 32rem);
  }

  .mood-gallery__side {
    margin: 0;
    position: relative;
  }

  /**
   * Links: deutlich breiter, von links in die Mitte über „Atmosphäre“
   */
  .mood-gallery__side--left {
    justify-self: end;
    z-index: 2;
    width: min(100%, 42rem);
    max-width: min(92vw, 42rem);
    margin-right: clamp(-7rem, -16vw, -2.5rem);
    transform: translateX(clamp(1.25rem, 11vw, 6.5rem));
  }

  /**
   * Rechts: von rechts über den Schriftzug
   */
  .mood-gallery__side--right {
    justify-self: start;
    z-index: 2;
    width: min(100%, 27rem);
    max-width: min(58vw, 27rem);
    margin-left: clamp(-6rem, -14vw, -2rem);
    margin-top: clamp(1.5rem, 4.5vw, 3.5rem);
    transform: translateX(clamp(-1.25rem, -11vw, -6.5rem));
  }

  .mood-gallery__frame {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    box-shadow: var(--shadow-card);
    background: var(--color-line);
  }

  /* Empfang: breiteres Format (mehr Breite pro Höhe), wirkt größer in die Mitte */
  .mood-gallery__frame--left-wide {
    aspect-ratio: 5 / 6;
  }

  .mood-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.9s var(--ease-luxe);
  }

  .mood-gallery__side--left .mood-gallery__img {
    object-position: 42% 48%;
  }

  .mood-gallery__side--right .mood-gallery__img {
    object-position: 62% 44%;
  }

  @media (hover: hover) {
    .mood-gallery__frame:hover .mood-gallery__img {
      transform: scale(1.03);
    }
  }

  @media (max-width: 640px) {
    .mood-gallery__dual {
      grid-template-columns: 1fr;
      min-height: 0;
      gap: var(--space-md);
    }

    .mood-gallery__watermark {
      font-size: clamp(2.2rem, 11vw, 3.5rem);
      top: 44%;
    }

    .mood-gallery__side--left {
      justify-self: start;
      width: min(100%, 22rem);
      max-width: min(88vw, 22rem);
      margin-right: 0;
      transform: translateX(-4%);
    }

    .mood-gallery__side--right {
      justify-self: end;
      width: min(100%, 19rem);
      max-width: min(82vw, 19rem);
      margin-left: 0;
      margin-top: -0.35rem;
      transform: translateX(4%);
    }

    .mood-gallery__frame--left-wide {
      aspect-ratio: 4 / 5;
    }
  }
</style>
