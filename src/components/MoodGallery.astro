---
/**
 * Atmosphäre: Bild links / rechts, Schriftzug in der Mitte sichtbar;
 * nur leichte Überlappung (~2 %) Richtung Wortmitte.
 */
import { SALON_IMAGES } from "../data/salon-images";

const leftShot = {
  src: SALON_IMAGES.atmosphereReception.src,
  w: SALON_IMAGES.atmosphereReception.w,
  h: SALON_IMAGES.atmosphereReception.h,
  alt: "Salon — Empfang und Beratung",
};

const rightShot = {
  src: SALON_IMAGES.atmosphereStyling.src,
  w: SALON_IMAGES.atmosphereStyling.w,
  h: SALON_IMAGES.atmosphereStyling.h,
  alt: "Salon — Stylingplätze und Lichtstimmung",
};
---

<section class="mood-gallery section" id="stimmung" aria-labelledby="mood-heading">
  <h2 id="mood-heading" class="mood-gallery__sr-only">Atmosphäre</h2>
  <div class="mood-gallery__wrap">
    <div class="mood-gallery__watermark" aria-hidden="true">Atmosphäre</div>
    <div class="mood-gallery__dual">
      <figure class="mood-gallery__side mood-gallery__side--left" data-reveal style="--reveal-delay: 0ms">
        <div class="mood-gallery__frame">
          <img
            src={leftShot.src}
            alt={leftShot.alt}
            width={leftShot.w}
            height={leftShot.h}
            loading="lazy"
            decoding="async"
            class="mood-gallery__img"
          />
        </div>
      </figure>
      <figure class="mood-gallery__side mood-gallery__side--right" data-reveal style="--reveal-delay: 90ms">
        <div class="mood-gallery__frame">
          <img
            src={rightShot.src}
            alt={rightShot.alt}
            width={rightShot.w}
            height={rightShot.h}
            loading="lazy"
            decoding="async"
            class="mood-gallery__img"
          />
        </div>
      </figure>
    </div>
  </div>
</section>

<style>
  .mood-gallery {
    position: relative;
    overflow-x: clip;
    overflow-y: visible;
    padding-block: clamp(var(--space-2xl), 8vw, 5.5rem);
  }

  .mood-gallery__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /** Volle Breite inkl. Seitenrand (page-pad) */
  .mood-gallery__wrap {
    position: relative;
    z-index: 0;
    isolation: isolate;
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    padding-inline: max(var(--page-pad), env(safe-area-inset-left, 0px))
      max(var(--page-pad), env(safe-area-inset-right, 0px));
    box-sizing: border-box;
  }

  /** Schriftzug mittig, in der Grid-Lücke sichtbar; unter den Bildern nur an den Innenkanten */
  .mood-gallery__watermark {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
    width: 100%;
    max-width: 100%;
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 13vw, 9.5rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-editorial);
    opacity: 0.085;
    pointer-events: none;
    white-space: nowrap;
    padding-inline: var(--page-pad);
    box-sizing: border-box;
  }

  .mood-gallery__dual {
    --mood-word-nudge: clamp(0.2rem, 2vw, 0.85rem);
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    column-gap: clamp(2rem, 12vw, 7rem);
    align-items: center;
    min-height: min(48vw, 28rem);
  }

  .mood-gallery__side {
    margin: 0;
    position: relative;
    z-index: 2;
  }

  /* Links am Rand, Innenkante minimal (~2 %) Richtung Schriftzug */
  .mood-gallery__side--left {
    justify-self: start;
    width: min(100%, 26rem);
    max-width: min(44vw, 26rem);
    transform: translateX(var(--mood-word-nudge));
  }

  /* Rechts am Rand, spiegelbildlich leicht ins Wort */
  .mood-gallery__side--right {
    justify-self: end;
    width: min(100%, 26rem);
    max-width: min(44vw, 26rem);
    margin-top: clamp(1rem, 3.5vw, 2.75rem);
    transform: translateX(calc(-1 * var(--mood-word-nudge)));
  }

  .mood-gallery__frame {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    box-shadow: var(--shadow-card);
    background: var(--color-line);
  }

  .mood-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.9s var(--ease-luxe);
  }

  .mood-gallery__side--left .mood-gallery__img {
    object-position: 42% 48%;
  }

  .mood-gallery__side--right .mood-gallery__img {
    object-position: 62% 44%;
  }

  @media (hover: hover) {
    .mood-gallery__frame:hover .mood-gallery__img {
      transform: scale(1.03);
    }
  }

  @media (max-width: 640px) {
    .mood-gallery {
      padding-block: clamp(var(--space-2xl), 10vw, 6rem);
    }

    .mood-gallery__dual {
      grid-template-columns: 1fr;
      row-gap: var(--space-lg);
      column-gap: 0;
      min-height: 0;
    }

    .mood-gallery__watermark {
      font-size: clamp(2.5rem, 12.5vw, 4rem);
      top: 48%;
    }

    .mood-gallery__side--left {
      justify-self: stretch;
      width: 100%;
      max-width: none;
      transform: translate(0, -8px);
    }

    .mood-gallery__side--right {
      justify-self: stretch;
      width: 100%;
      max-width: none;
      margin-top: 0;
      transform: translate(0, 12px);
    }

    .mood-gallery__frame {
      aspect-ratio: 4 / 5;
      min-height: min(78vw, 26rem);
    }
  }
</style>
