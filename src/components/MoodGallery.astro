---
/**
 * Staggered Mood-Gallery mit Watermark-Typo (Editorial)
 */
const shots = [
  {
    src: "https://images.unsplash.com/photo-1560066984-138dadb4c035?auto=format&fit=crop&w=900&q=80",
    alt: "Salon-Atmosphäre",
    tall: true,
  },
  {
    src: "https://images.unsplash.com/photo-1633681926022-84c23e8cb2d6?auto=format&fit=crop&w=900&q=80",
    alt: "Color & Styling",
    tall: false,
  },
  {
    src: "https://images.unsplash.com/photo-1519699047748-de8e457a634e?auto=format&fit=crop&w=900&q=80",
    alt: "Pflege-Moment",
    tall: false,
  },
];
---

<section class="mood-gallery section" id="stimmung" aria-labelledby="mood-heading">
  <div class="mood-gallery__watermark" aria-hidden="true">Atmosphäre</div>
  <div class="container mood-gallery__wrap">
    <h2 id="mood-heading" class="mood-gallery__heading">Ein Ort zum Ankommen</h2>
    <p class="mood-gallery__lead muted">
      Licht, Material und Ruhe — bevor Sie Platz nehmen, spüren Sie schon: hier wird sorgsam gearbeitet.
    </p>
    <div class="mood-gallery__grid">
      {
        shots.map((s, i) => (
          <figure class:list={["mood-gallery__fig", s.tall && "mood-gallery__fig--tall"]} data-reveal style={`--reveal-delay: ${i * 90}ms`}>
            <div class="mood-gallery__frame">
              <img src={s.src} alt={s.alt} width="900" height={1120} loading="lazy" decoding="async" class="mood-gallery__img" />
            </div>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .mood-gallery {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-2xl);
  }

  .mood-gallery__watermark {
    position: absolute;
    left: 0;
    right: 0;
    top: 1rem;
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 16vw, 11rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--color-editorial);
    opacity: 0.04;
    pointer-events: none;
    white-space: nowrap;
  }

  .mood-gallery__wrap {
    position: relative;
    z-index: 1;
  }

  .mood-gallery__heading {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 3.5vw, 2.35rem);
    letter-spacing: -0.02em;
    color: var(--color-editorial);
    max-width: 22rem;
  }

  .mood-gallery__lead {
    margin: 0 0 var(--space-xl);
    max-width: 32rem;
    font-size: 1rem;
    line-height: 1.65;
  }

  .mood-gallery__grid {
    display: grid;
    gap: var(--space-md);
    align-items: start;
  }

  @media (min-width: 768px) {
    .mood-gallery__grid {
      grid-template-columns: 1.1fr 0.9fr 0.9fr;
      gap: var(--space-lg);
    }

    .mood-gallery__fig--tall {
      margin-top: -2.5rem;
    }

    .mood-gallery__fig:nth-child(2) {
      margin-top: 2rem;
    }
  }

  .mood-gallery__fig {
    margin: 0;
  }

  .mood-gallery__frame {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    box-shadow: var(--shadow-card);
    background: var(--color-line);
  }

  .mood-gallery__fig--tall .mood-gallery__frame {
    aspect-ratio: 3 / 4;
  }

  .mood-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.9s var(--ease-luxe);
  }

  @media (hover: hover) {
    .mood-gallery__frame:hover .mood-gallery__img {
      transform: scale(1.03);
    }
  }
</style>
