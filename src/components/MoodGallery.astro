---
/**
 * Atmosphäre: zwei Motive links/rechts versetzt, großer Schriftzug mittig im Hintergrund
 */
import { SALON_IMAGES } from "../data/salon-images";

const leftShot = {
  src: SALON_IMAGES.mood3.src,
  w: SALON_IMAGES.mood3.w,
  h: SALON_IMAGES.mood3.h,
  alt: "Im Salon — Details und Ruhe",
};

const rightShot = {
  src: SALON_IMAGES.feature.src,
  w: SALON_IMAGES.feature.w,
  h: SALON_IMAGES.feature.h,
  alt: "Salon — Beratung und Handwerk",
};
---

<section class="mood-gallery section" id="stimmung" aria-labelledby="mood-heading">
  <h2 id="mood-heading" class="mood-gallery__sr-only">Atmosphäre</h2>
  <div class="mood-gallery__watermark" aria-hidden="true">Atmosphäre</div>
  <div class="container mood-gallery__wrap">
    <div class="mood-gallery__dual">
      <figure class="mood-gallery__side mood-gallery__side--left" data-reveal style="--reveal-delay: 0ms">
        <div class="mood-gallery__frame">
          <img
            src={leftShot.src}
            alt={leftShot.alt}
            width={leftShot.w}
            height={leftShot.h}
            loading="lazy"
            decoding="async"
            class="mood-gallery__img"
          />
        </div>
      </figure>
      <figure class="mood-gallery__side mood-gallery__side--right" data-reveal style="--reveal-delay: 90ms">
        <div class="mood-gallery__frame">
          <img
            src={rightShot.src}
            alt={rightShot.alt}
            width={rightShot.w}
            height={rightShot.h}
            loading="lazy"
            decoding="async"
            class="mood-gallery__img"
          />
        </div>
      </figure>
    </div>
  </div>
</section>

<style>
  .mood-gallery {
    position: relative;
    overflow: hidden;
    padding-block: clamp(var(--space-2xl), 8vw, 5.5rem);
  }

  .mood-gallery__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .mood-gallery__watermark {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
    width: 100%;
    max-width: 100%;
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(3rem, 14vw, 10rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-editorial);
    opacity: 0.055;
    pointer-events: none;
    white-space: nowrap;
    padding-inline: var(--page-pad);
    box-sizing: border-box;
  }

  .mood-gallery__wrap {
    position: relative;
    z-index: 1;
  }

  .mood-gallery__dual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(var(--space-sm), 3vw, var(--space-xl));
    align-items: start;
    min-height: min(58vw, 32rem);
  }

  .mood-gallery__side {
    margin: 0;
    width: min(100%, 22rem);
  }

  .mood-gallery__side--left {
    justify-self: start;
    margin-top: 0;
  }

  .mood-gallery__side--right {
    justify-self: end;
    margin-top: clamp(2.25rem, 7vw, 4.5rem);
  }

  .mood-gallery__frame {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    box-shadow: var(--shadow-card);
    background: var(--color-line);
  }

  .mood-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.9s var(--ease-luxe);
  }

  @media (hover: hover) {
    .mood-gallery__frame:hover .mood-gallery__img {
      transform: scale(1.03);
    }
  }

  @media (max-width: 640px) {
    .mood-gallery__dual {
      grid-template-columns: 1fr;
      min-height: 0;
      gap: var(--space-lg);
    }

    .mood-gallery__side {
      width: min(100%, 19rem);
    }

    .mood-gallery__side--left {
      justify-self: start;
      margin-inline: 0 auto;
      margin-top: 0;
    }

    .mood-gallery__side--right {
      justify-self: end;
      margin-inline: auto 0;
      margin-top: -0.75rem;
    }
  }
</style>
