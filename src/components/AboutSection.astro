---
import SectionHeading from "./SectionHeading.astro";
import BookingButton from "./BookingButton.astro";
import { SITE } from "../data/site";

const imgA = {
  src: "https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?auto=format&fit=crop&w=800&q=80",
  alt: "Styling im Detail",
};
const imgB = {
  src: "https://images.unsplash.com/photo-1503951914875-452162b0f3f1?auto=format&fit=crop&w=800&q=80",
  alt: "Team am Arbeiten — Platzhalter",
};
---

<section class="section about about--split" id="ueber-uns" aria-labelledby="about-heading">
  <div class="container">
    <div class="about__split">
      <div class="about__visual" data-reveal style="--reveal-delay: 0ms">
        <svg class="about__branch" viewBox="0 0 200 280" fill="none" aria-hidden="true">
          <path
            d="M40 260 C 60 180, 20 120, 80 80 C 120 50, 100 20, 140 10 C 170 5, 185 40, 160 70"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"
            opacity="0.2"
          ></path>
          <path
            d="M100 200 C 130 160, 110 100, 160 60"
            stroke="currentColor"
            stroke-width="1"
            stroke-linecap="round"
            opacity="0.15"
          ></path>
        </svg>
        <div class="about__stack">
          <figure class="about__fig about__fig--sm">
            <img src={imgA.src} alt={imgA.alt} width="800" height="1000" loading="lazy" decoding="async" />
          </figure>
          <figure class="about__fig about__fig--lg">
            <img src={imgB.src} alt={imgB.alt} width="800" height="600" loading="lazy" decoding="async" />
          </figure>
        </div>
      </div>

      <div class="about__copy" data-reveal style="--reveal-delay: 100ms">
        <SectionHeading
          eyebrow="Über uns"
          title="Eine Marke, die leise überzeugt"
          subtitle={`${SITE.name} steht für Meisterqualität in ${SITE.city}: weniger Show, mehr Substanz. Wir glauben an Haar, das sich im Alltag bewährt — und an Beziehungen, die wachsen, weil wir liefern.`}
          headingId="about-heading"
        />
        <ul class="about__list" role="list">
          <li>
            <strong>Beratung mit Respekt</strong>
            <span class="muted"> — wir fragen, zuhören und übersetzen Wünsche in machbare Looks.</span>
          </li>
          <li>
            <strong>Hygiene &amp; Ordnung</strong>
            <span class="muted"> — selbstverständlich, ohne darauf groß zu reden.</span>
          </li>
          <li>
            <strong>Ruhrgebiet-Verwurzelung</strong>
            <span class="muted"> — nah, persönlich, ohne Schnörkel: Qualität, die bleibt.</span>
          </li>
        </ul>
        <BookingButton />
      </div>
    </div>
  </div>
</section>

<style>
  .about--split .about__split {
    display: grid;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 960px) {
    .about--split .about__split {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
  }

  .about__visual {
    position: relative;
    min-height: 320px;
  }

  .about__branch {
    position: absolute;
    left: -5%;
    top: -4%;
    width: 55%;
    max-width: 220px;
    height: auto;
    color: var(--color-accent);
    pointer-events: none;
    z-index: 0;
  }

  .about__stack {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: var(--space-md);
    align-items: end;
    padding-left: var(--space-sm);
  }

  .about__fig {
    margin: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    background: var(--color-line);
  }

  .about__fig--sm {
    align-self: start;
    margin-top: 2rem;
  }

  .about__fig img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about__fig--sm img {
    aspect-ratio: 3 / 4;
  }

  .about__fig--lg img {
    aspect-ratio: 4 / 3;
  }

  .about__copy :global(.section-heading) {
    margin-bottom: var(--space-lg);
  }

  .about__list {
    margin: 0 0 var(--space-lg);
    padding-left: 1.1rem;
    max-width: 36rem;
  }

  .about__list li {
    margin-bottom: var(--space-sm);
  }
</style>
