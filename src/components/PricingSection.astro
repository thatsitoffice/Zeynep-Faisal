---
import SectionHeading from "./SectionHeading.astro";
import BookingButton from "./BookingButton.astro";

/**
 * Preise als Orientierung — finale Preise immer in Planity / vor Ort bestätigen.
 */
const groups = [
  {
    name: "Damen",
    rows: [
      { service: "Waschen & Legen / Föhnen", price: "ab 32 €" },
      { service: "Haarschnitt Classic", price: "ab 48 €" },
      { service: "Haarschnitt inkl. Styling", price: "ab 62 €" },
      { service: "Ansatzfarbe", price: "ab 55 €" },
      { service: "Ganzköpfige Coloration / Glossing", price: "ab 78 €" },
    ],
  },
  {
    name: "Herren",
    rows: [
      { service: "Haarschnitt", price: "ab 32 €" },
      { service: "Waschen & Styling", price: "ab 26 €" },
      { service: "Bartpflege (optional)", price: "ab 18 €" },
    ],
  },
  {
    name: "Extras & Pflege",
    rows: [
      { service: "Intensivkur / Maske", price: "ab 18 €" },
      { service: "Kopfmassage-Upgrade", price: "ab 12 €" },
      { service: "Express-Glanzfinish", price: "ab 15 €" },
    ],
  },
];
---

<section class="section pricing" id="preise" aria-labelledby="pricing-heading">
  <div class="container">
    <SectionHeading
      eyebrow="Preise"
      title="Transparent — ohne Überraschungen an der Kasse"
      subtitle="Alle „ab“-Preise sind bewusst ehrlich formuliert. Der finale Betrag hängt von Länge, Aufwand und Produktwahl ab — besprochen vor dem Start."
      headingId="pricing-heading"
    />

    <div class="pricing__grid">
      {
        groups.map((g) => (
          <div class="card pricing__card" data-reveal>
            <h3 class="display-md" style="margin: 0 0 var(--space-md); font-size: 1.65rem;">
              {g.name}
            </h3>
            <table class="price-table">
              <thead>
                <tr>
                  <th scope="col">Leistung</th>
                  <th scope="col">ab</th>
                </tr>
              </thead>
              <tbody>
                {g.rows.map((r) => (
                  <tr>
                    <td>{r.service}</td>
                    <td>{r.price}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ))
      }
    </div>

    <p class="pricing__note muted" data-reveal>
      Hinweis: Preise Stand Platzhalter — bitte mit Ihrer aktuellen Preisliste synchronisieren. Änderungen nur in dieser Komponente oder ausgelagert in `src/data/pricing.ts`.
    </p>

    <div class="pricing__cta" data-reveal>
      <BookingButton />
      <p class="muted" style="margin: 0; font-size: 0.9rem; max-width: 22rem;">
        Im Buchungstool sehen Sie verfügbare Slots und zugeordnete Leistungen in Echtzeit.
      </p>
    </div>
  </div>
</section>

<style>
  .pricing__grid {
    display: grid;
    gap: var(--space-md);
  }

  @media (min-width: 900px) {
    .pricing__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pricing__note {
    margin-top: var(--space-lg);
    font-size: 0.875rem;
    max-width: 48rem;
  }

  .pricing__cta {
    margin-top: var(--space-xl);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
  }
</style>
