---
import SectionHeading from "./SectionHeading.astro";

/**
 * Kompakter Überblick — weniger Höhe, gleiche Inhalte verdichtet.
 */
const items = [
  {
    title: "Schnitt & Form",
    text: "Silhouette und Bewegung — abgestimmt auf Struktur und Alltag.",
  },
  {
    title: "Farbe & Licht",
    text: "Balayage, Naturton oder Kontur — gesund wirkend, edel im Verlauf.",
  },
  {
    title: "Pflege & Finish",
    text: "Substanz, Glanz, Schutz — was Ihr Haar wirklich braucht.",
  },
];
---

<section class="section services services--compact" id="leistungen" aria-labelledby="services-heading">
  <div class="container">
    <SectionHeading
      eyebrow="Leistungen"
      title="Schnitt, Farbe, Pflege — auf einen Blick"
      subtitle="Details und aktuelle Preise finden Sie auf der Preisseite. Im Termin klären wir alles Weitere in Ruhe."
      headingId="services-heading"
    />

    <ul class="services__grid" role="list">
      {
        items.map((item, i) => (
          <li class="services__card" data-reveal style={`--reveal-delay: ${i * 70}ms`}>
            <h3 class="services__card-title">{item.title}</h3>
            <p class="services__card-text">{item.text}</p>
          </li>
        ))
      }
    </ul>

    <p class="services__cta" data-reveal>
      <a class="btn btn--primary" href="/preise/">Komplette Preisliste</a>
    </p>
  </div>
</section>

<style>
  .services--compact {
    padding-block: var(--space-xl);
  }

  .services--compact :global(.section-heading) {
    margin-bottom: var(--space-md);
  }

  .services__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-sm);
  }

  @media (min-width: 720px) {
    .services__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-md);
    }
  }

  .services__card {
    margin: 0;
    padding: var(--space-md) var(--space-md);
    background: var(--color-bg-elevated);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-card);
  }

  .services__card-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .services__card-text {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.62;
    color: var(--color-ink-muted);
  }

  .services__cta {
    margin: var(--space-lg) 0 0;
    text-align: center;
  }

  @media (min-width: 720px) {
    .services__cta {
      text-align: left;
    }
  }
</style>
