---
import SectionHeading from "./SectionHeading.astro";
import TrustGoogleRibbon from "./TrustGoogleRibbon.astro";

const pillars = [
  {
    title: "Meisterbetrieb",
    text: "Zwei Meister:innen, ein Anspruch: Technik, die hält — und ein Look, der zu Ihrem Leben passt, nicht zur nächsten Trendwelle.",
  },
  {
    title: "Qualität ohne Kompromiss",
    text: "Wir arbeiten mit ausgewählten Produkten und klaren Schritten. Was wir versprechen, können wir wiederholen — Termin für Termin.",
  },
  {
    title: "Ruhe statt Lautstärke",
    text: "Kein hektisches „Rein-Raus“. Stattdessen: Fokus, Zeit für Details und eine Atmosphäre, in der Sie durchatmen können.",
  },
];
---

<section class="section trust" id="vertrauen" aria-labelledby="trust-heading">
  <div class="container">
    <SectionHeading
      eyebrow="Vertrauen"
      title="Handwerk, das man spürt — und sieht"
      subtitle="Im Ruhrgebiet zu Hause, mit dem Anspruch einer Boutique: persönlich, präzise, diskret exzellent."
      headingId="trust-heading"
    />

    <TrustGoogleRibbon />

    <ul class="trust__grid" role="list">
      {
        pillars.map((p, i) => (
          <li
            class="trust__card"
            data-reveal
            style={`--reveal-delay: ${80 + i * 100}ms`}
          >
            <div class="trust__card-inner">
              <span class="trust__index" aria-hidden="true">
                {String(i + 1).padStart(2, "0")}
              </span>
              <h3 class="trust__card-title">{p.title}</h3>
              <p class="trust__card-text">{p.text}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .trust__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .trust__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }
  }

  .trust__card {
    margin: 0;
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-card);
    transition:
      transform 0.5s var(--ease-luxe),
      box-shadow 0.5s var(--ease-luxe),
      border-color 0.35s ease;
  }

  @media (hover: hover) {
    .trust__card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lift);
      border-color: rgba(28, 27, 25, 0.1);
    }
  }

  .trust__card-inner {
    padding: var(--space-lg) var(--space-lg) var(--space-lg) var(--space-lg);
    position: relative;
  }

  .trust__index {
    display: block;
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    opacity: 0.85;
    margin-bottom: var(--space-sm);
  }

  .trust__card-title {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.2vw, 1.6rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .trust__card-text {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.62;
    color: var(--color-ink-muted);
  }
</style>
