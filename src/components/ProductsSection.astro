---
import SectionHeading from "./SectionHeading.astro";
import BookingButton from "./BookingButton.astro";
import { SALON_IMAGES } from "../data/salon-images";

const banner = SALON_IMAGES.productsBanner;
---

<section class="section products" id="produkte" aria-labelledby="products-heading">
  <div class="container">
    <SectionHeading
      eyebrow="Produkte"
      title="Redken im Salon — Pflege mit Substanz"
      subtitle="Von intensiver Aufbau-Pflege bis zu Styling und Finish: Wir arbeiten mit klaren Profilinien und zeigen Ihnen im Salon, welche Texturen und Routinen zu Ihrer Haarstruktur passen — mitnehmen, was sich für Sie lohnt."
      headingId="products-heading"
    />
  </div>

  <div class="products__bleed" data-reveal>
    <figure class="products__figure">
      <div class="products__frame">
        <img
          class="products__img"
          src={banner.src}
          alt="Große Auswahl an Redken Haarpflege- und Stylingprodukten — im Salon erhältlich und zur Beratung"
          width={banner.w}
          height={banner.h}
          loading="lazy"
          decoding="async"
        />
      </div>
    </figure>
  </div>

  <div class="container">
    <div class="products__footer" data-reveal>
      <p class="lead" style="margin: 0;">
        Marken mit nachvollziehbaren Inhaltsstoffen — vor Ort beraten wir Sie zu Struktur, Pflege zu Hause und passenden Finish-Produkten.
      </p>
      <BookingButton variant="ghost" />
    </div>
  </div>
</section>

<style>
  .products__bleed {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-md);
    padding-inline: max(var(--page-pad), env(safe-area-inset-left, 0px))
      max(var(--page-pad), env(safe-area-inset-right, 0px));
    box-sizing: border-box;
  }

  .products__figure {
    margin: 0;
    max-width: 100%;
  }

  .products__frame {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #0c0c0c;
    box-shadow: var(--shadow-card);
    border: 1px solid rgba(20, 19, 18, 0.12);
  }

  .products__img {
    width: 100%;
    height: auto;
    display: block;
    vertical-align: middle;
  }

  .products__footer {
    margin-top: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .products__footer {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
