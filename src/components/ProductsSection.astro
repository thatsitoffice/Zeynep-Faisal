---
import SectionHeading from "./SectionHeading.astro";
import BookingButton from "./BookingButton.astro";

/**
 * Horizontale Übersicht — Platzhalter-Motiv bis eigene Produktfotos in /public liegen.
 * Eigene Bilder: z. B. src: "/images/produkt-1.jpg"
 */
const products = [
  {
    name: "Salon-Pflege",
    line: "Shampoo & Kur",
    src: "https://images.unsplash.com/photo-1620916566398-39f1143ab7be?auto=format&fit=crop&w=700&q=82",
    alt: "Haarpflegeprodukte in Flaschen — stellvertretend fürs Sortiment",
  },
  {
    name: "Serum & Öl",
    line: "Struktur & Glanz",
    src: "https://images.unsplash.com/photo-1556228578-8d85aab2b8bb?auto=format&fit=crop&w=700&q=82",
    alt: "Pflegeöl und Serum in Glasflaschen",
  },
  {
    name: "Styling",
    line: "Finish & Halt",
    src: "https://images.unsplash.com/photo-1522338242992-e1a5492a4fd4?auto=format&fit=crop&w=700&q=82",
    alt: "Stylingprodukte und Sprays",
  },
  {
    name: "Kopfhaut",
    line: "Balance & Ruhe",
    src: "https://images.unsplash.com/photo-1571875257727-256c39da42af?auto=format&fit=crop&w=700&q=82",
    alt: "Kosmetikflaschen für sensible Pflege",
  },
  {
    name: "Color-Pflege",
    line: "Nach dem Service",
    src: "https://images.unsplash.com/photo-1596462502278-27bfdc403348?auto=format&fit=crop&w=700&q=82",
    alt: "Produktflaschen für coloriertes Haar",
  },
  {
    name: "Finish",
    line: "Spray & Schutz",
    src: "https://images.unsplash.com/photo-1608248597279-f99d160bfcbc?auto=format&fit=crop&w=700&q=82",
    alt: "Feines Spray und Pflegeprodukte",
  },
];
---

<section class="section products" id="produkte" aria-labelledby="products-heading">
  <div class="container">
    <SectionHeading
      eyebrow="Produkte"
      title="Was wir auftragen — und Ihnen mitgeben"
      subtitle="Kurzer Überblick über unser Sortiment. Im Salon zeigen wir Ihnen passende Texturen und Marken — mitnehmen, was zu Ihrer Routine passt."
      headingId="products-heading"
    />
  </div>

  <div class="products__bleed" aria-label="Produktübersicht zum Wischen">
    <div class="products__strip" tabindex="0">
      {
        products.map((p, i) => (
          <figure class="products__item" data-reveal style={`--reveal-delay: ${i * 55}ms`}>
            <div class="products__frame">
              <img
                class="products__img"
                src={p.src}
                alt={p.alt}
                width={700}
                height={875}
                loading={i < 3 ? "eager" : "lazy"}
                decoding="async"
              />
            </div>
            <figcaption class="products__cap">
              <span class="products__name">{p.name}</span>
              <span class="products__line muted">{p.line}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
    <p class="products__scroll-hint muted container" aria-hidden="true">
      ← Zurück · Weiter →
    </p>
  </div>

  <div class="container">
    <div class="products__footer" data-reveal>
      <p class="lead" style="margin: 0;">
        Marken mit klaren Inhaltsstoffen — gerne beraten wir Sie vor Ort zu Ihrer Haarstruktur und Pflege zu Hause.
      </p>
      <BookingButton variant="ghost" />
    </div>
  </div>
</section>

<style>
  .products__bleed {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .products__strip {
    display: flex;
    gap: var(--space-md);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-inline: var(--page-pad);
    padding-inline: var(--page-pad);
    padding-bottom: var(--space-sm);
    -webkit-overflow-scrolling: touch;
    scrollbar-gutter: stable;
  }

  .products__strip:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  .products__item {
    flex: 0 0 min(200px, 42vw);
    margin: 0;
    scroll-snap-align: start;
  }

  @media (min-width: 640px) {
    .products__item {
      flex-basis: min(220px, 32vw);
    }
  }

  @media (min-width: 900px) {
    .products__item {
      flex-basis: min(240px, 22vw);
    }
  }

  .products__frame {
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-line);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-line);
  }

  .products__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
    transition: transform 0.65s var(--ease-luxe);
  }

  @media (hover: hover) {
    .products__item:hover .products__img {
      transform: scale(1.04);
    }
  }

  .products__cap {
    margin-top: var(--space-sm);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    text-align: left;
  }

  .products__name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .products__line {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .products__scroll-hint {
    margin: 0;
    padding-inline: var(--page-pad);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-align: center;
    opacity: 0.65;
  }

  @media (min-width: 1100px) {
    .products__scroll-hint {
      text-align: right;
      padding-right: var(--page-pad);
    }
  }

  .products__footer {
    margin-top: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .products__footer {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .products__img {
      transition: none;
    }

    .products__item:hover .products__img {
      transform: none;
    }
  }
</style>
