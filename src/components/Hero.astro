---
import BookingButton from "./BookingButton.astro";
import GoogleRatingChip from "./GoogleRatingChip.astro";
import { SITE } from "../data/site";

/** Helles, freundliches Salon-Interieur */
const bg = {
  src: "https://images.unsplash.com/photo-1562320340-20b163c733bf?auto=format&fit=crop&w=2400&q=88",
};
---

<section class="hero hero--editorial hero--invite" id="top" aria-labelledby="hero-heading">
  <div class="hero__media" aria-hidden="true">
    <img
      src={bg.src}
      alt=""
      width={2400}
      height={1350}
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="hero__bg-img"
    />
  </div>
  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="hero__inner container">
    <div class="hero__stack" data-reveal style="--reveal-delay: 0ms">
      <p class="hero__intro">
        Willkommen in Ihrem Meisterbetrieb in {SITE.city}: ruhige Beratung, klare Hände, Schnitt und Farbe mit Substanz
        — Ihr wiederkehrender Moment für Haar, das sich im Alltag bewährt.
      </p>

      <h1 id="hero-heading" class="hero__title">
        <span class="hero__title-line">New Style</span>
        <span class="hero__title-line hero__title-line--sub">by Zeynep &amp; Faisal</span>
      </h1>

      <div class="hero__actions-row">
        <GoogleRatingChip variant="hero" />
        <div class="hero__cta-group">
          <BookingButton variant="heroSolid" />
          <a class="btn btn--hero-outline" href="/preise/">Preise &amp; Leistungen</a>
        </div>
      </div>

      <p class="hero__hint">
        <a class="hero__hint-link" href="#vertrauen">Vorteile entdecken</a>
        <span class="hero__dot" aria-hidden="true">·</span>
        <a class="hero__hint-link" href={SITE.bookingUrl} target="_blank" rel="noopener noreferrer">Direkt zu Planity</a>
      </p>
    </div>
  </div>
</section>

<style>
  .hero--editorial.hero--invite {
    position: relative;
    min-height: min(100vh, 980px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-top: calc(var(--header-h) + 1.5rem);
    padding-bottom: clamp(1.5rem, 5vh, 3.25rem);
    overflow: hidden;
    color: rgba(255, 255, 255, 0.98);
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    filter: saturate(1.08) brightness(1.03);
  }

  /* Helleres Bild: nur unten/links abdunkeln für Lesbarkeit */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(18, 16, 14, 0.12) 0%, rgba(18, 16, 14, 0.08) 50%, rgba(14, 12, 11, 0.55) 100%),
      linear-gradient(90deg, rgba(12, 11, 10, 0.5) 0%, rgba(12, 11, 10, 0.15) 55%, transparent 78%);
  }

  .hero__inner {
    position: relative;
    z-index: 2;
  }

  .hero__stack {
    max-width: min(56rem, 100%);
    padding-bottom: env(safe-area-inset-bottom, 0);
  }

  .hero__intro {
    margin: 0 0 1.1rem;
    max-width: 38rem;
    font-family: var(--font-body);
    font-size: clamp(0.72rem, 1.85vw, 0.88rem);
    font-weight: 600;
    line-height: 1.82;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.35);
  }

  .hero__title {
    margin: 0 0 1.35rem;
    padding: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(3rem, 10vw, 6rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: #fff;
    text-shadow: 0 4px 36px rgba(0, 0, 0, 0.28);
  }

  .hero__title-line {
    display: block;
  }

  .hero__title-line--sub {
    font-size: 0.48em;
    font-weight: 400;
    letter-spacing: 0.02em;
    margin-top: 0.1em;
    opacity: 0.95;
  }

  @media (min-width: 720px) {
    .hero__title-line {
      margin-left: -0.02em;
    }
  }

  .hero__actions-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.25rem;
    margin-bottom: 1rem;
  }

  .hero__cta-group {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
  }

  .hero__cta-group :global(.btn) {
    min-height: 3.15rem;
    padding-inline: 1.5rem;
    font-size: 0.8rem;
  }

  .hero__hint {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.5rem;
    font-family: var(--font-body);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
  }

  .hero__dot {
    opacity: 0.45;
  }

  .hero__hint-link {
    color: rgba(255, 255, 255, 0.92);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.35);
    padding-bottom: 0.1em;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .hero__hint-link:hover {
    color: #fff;
    border-bottom-color: rgba(255, 255, 255, 0.75);
  }

  @media (max-width: 520px) {
    .hero__intro {
      letter-spacing: 0.14em;
    }

    .hero__cta-group {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__cta-group :global(.btn) {
      justify-content: center;
    }
  }
</style>
