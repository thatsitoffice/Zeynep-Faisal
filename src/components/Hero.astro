---
import BookingButton from "./BookingButton.astro";
import GoogleRatingChip from "./GoogleRatingChip.astro";
import { SITE } from "../data/site";
import { SALON_IMAGES } from "../data/salon-images";

const bg = SALON_IMAGES.hero;
---

<section class="hero hero--editorial hero--invite" id="top" aria-labelledby="hero-heading">
  <div class="hero__media" aria-hidden="true">
    <img
      src={bg.src}
      alt=""
      width={bg.w}
      height={bg.h}
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="hero__bg-img"
    />
  </div>
  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="hero__inner">
    <div class="hero__stack" data-reveal style="--reveal-delay: 0ms">
      <h1 id="hero-heading" class="hero__title">
        <span class="hero__title-line">New Style</span>
        <span class="hero__title-line hero__title-line--sub">by Zeynep &amp; Faisal</span>
      </h1>

      <p class="hero__intro">
        Willkommen in Ihrem Meisterbetrieb in {SITE.city}: ruhige Beratung, klare Hände, Schnitt und Farbe mit Substanz
        — Ihr wiederkehrender Moment für Haar, das sich im Alltag bewährt.
      </p>

      <div class="hero__actions-row">
        <GoogleRatingChip variant="hero" />
        <div class="hero__cta-group">
          <BookingButton variant="heroSolid" />
          <a class="btn btn--hero-outline" href="/preise/">Preise &amp; Leistungen</a>
        </div>
      </div>

      <p class="hero__hint">
        <a class="hero__hint-link" href="#vertrauen">Vorteile entdecken</a>
        <span class="hero__dot" aria-hidden="true">·</span>
        <a class="hero__hint-link" href={SITE.bookingUrl} target="_blank" rel="noopener noreferrer">Direkt zu Planity</a>
      </p>
    </div>
  </div>
</section>

<style>
  .hero--editorial.hero--invite {
    position: relative;
    min-height: min(100vh, 980px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: calc(var(--header-h) + 1.25rem);
    padding-bottom: clamp(2rem, 6vh, 3.5rem);
    overflow: hidden;
    color: rgba(255, 255, 255, 0.98);
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    filter: saturate(1.05) brightness(0.96);
  }

  /* Stärkeres Overlay für kontrastreichen Text */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(12, 10, 9, 0.35) 0%, rgba(12, 10, 9, 0.22) 45%, rgba(8, 7, 6, 0.72) 100%),
      linear-gradient(90deg, rgba(8, 7, 6, 0.68) 0%, rgba(8, 7, 6, 0.28) 52%, rgba(8, 7, 6, 0.08) 82%);
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-right: var(--page-pad);
    padding-left: var(--page-pad);
    box-sizing: border-box;
  }

  .hero__stack {
    margin-left: clamp(0%, 12vw, 20%);
    max-width: min(46rem, calc(100% - var(--page-pad)));
    padding-bottom: env(safe-area-inset-bottom, 0);
  }

  @media (max-width: 768px) {
    .hero__stack {
      margin-left: 0;
      max-width: 100%;
    }
  }

  .hero__intro {
    margin: 0 0 1.5rem;
    max-width: 42rem;
    font-family: var(--font-body);
    font-size: clamp(0.78rem, 2.1vw, 0.98rem);
    font-weight: 600;
    line-height: 1.75;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.94);
    text-shadow: 0 2px 22px rgba(0, 0, 0, 0.45);
  }

  .hero__title {
    margin: 0 0 1.2rem;
    padding: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(3.35rem, 11vw, 6.75rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: #fff;
    text-shadow: 0 6px 40px rgba(0, 0, 0, 0.38);
  }

  .hero__title-line {
    display: block;
  }

  .hero__title-line--sub {
    font-size: 0.48em;
    font-weight: 400;
    letter-spacing: 0.02em;
    margin-top: 0.1em;
    opacity: 0.95;
  }

  @media (min-width: 720px) {
    .hero__title-line {
      margin-left: -0.02em;
    }
  }

  .hero__actions-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.25rem;
    margin-bottom: 1rem;
  }

  .hero__cta-group {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
  }

  .hero__cta-group :global(.btn) {
    min-height: 3.45rem;
    padding-inline: 1.65rem;
    font-size: clamp(0.78rem, 1.8vw, 0.88rem);
  }

  .hero__hint {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.5rem;
    font-family: var(--font-body);
    font-size: clamp(0.78rem, 1.9vw, 0.84rem);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
  }

  .hero__dot {
    opacity: 0.45;
  }

  .hero__hint-link {
    color: rgba(255, 255, 255, 0.92);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.35);
    padding-bottom: 0.1em;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .hero__hint-link:hover {
    color: #fff;
    border-bottom-color: rgba(255, 255, 255, 0.75);
  }

  @media (max-width: 520px) {
    .hero__intro {
      letter-spacing: 0.14em;
    }

    .hero__cta-group {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__cta-group :global(.btn) {
      justify-content: center;
    }
  }
</style>
