---
import BookingButton from "./BookingButton.astro";
import { SITE } from "../data/site";

/**
 * Hero-Bild: Platzhalter — durch eigenes Shooting ersetzen (WebP/AVIF, ca. 1600px breit).
 * Quelle hier nur als hochwertiger Demo-Look; Rechte vor Veröffentlichung klären.
 */
const heroImage = {
  src: "https://images.unsplash.com/photo-1560066984-138dadb4c035?auto=format&fit=crop&w=1600&q=80",
  alt: "Ruhiger, heller Salonraum mit stilvoller Ausstattung — stellvertretend für die Atmosphäre bei New Style",
  width: 1600,
  height: 2000,
};
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__grid container">
    <div class="hero__copy" data-reveal>
      <p class="eyebrow">{SITE.city} · {SITE.tagline}</p>
      <h1 id="hero-heading" class="display-xl">
        Wo Präzision auf Ruhe trifft — Ihr Haar in Meisterhand.
      </h1>
      <p class="lead hero__lead">
        Im Herzen von Gelsenkirchen verwandeln wir Ihren Besuch in ein klares, hochwertiges Erlebnis: Beratung mit Tiefe,
        Handwerk mit Haltung — und ein Ergebnis, das sich jeden Tag leicht tragen lässt.
      </p>
      <div class="hero__actions">
        <BookingButton />
        <a class="btn btn--ghost" href="#leistungen">Leistungen entdecken</a>
      </div>
      <p class="hero__note muted">
        Online buchen bei Planity — Wunschtermin, Service und Team wählen Sie selbst.
      </p>
    </div>
    <figure class="hero__figure" data-reveal>
      <div class="hero__frame">
        <img
          src={heroImage.src}
          alt={heroImage.alt}
          width={heroImage.width}
          height={heroImage.height}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="hero__img"
        />
      </div>
      <figcaption class="hero__caption">Atmosphäre &amp; Handwerk — authentisches Bild nach Freigabe einsetzen.</figcaption>
    </figure>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-xl) var(--space-2xl);
    padding-top: calc(var(--space-xl) + var(--header-h));
    margin-top: calc(-1 * var(--header-h));
  }

  .hero__grid {
    display: grid;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 960px) {
    .hero__grid {
      grid-template-columns: 1fr 1.05fr;
      gap: var(--space-2xl);
    }
  }

  .hero__lead {
    margin-top: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .hero__note {
    font-size: 0.875rem;
    margin: 0;
    max-width: 28rem;
  }

  .hero__figure {
    margin: 0;
  }

  .hero__frame {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    aspect-ratio: 4 / 5;
    background: var(--color-line);
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__caption {
    margin-top: var(--space-sm);
    font-size: 0.75rem;
    color: var(--color-ink-soft);
    line-height: 1.4;
  }
</style>
