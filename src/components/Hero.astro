---
import { SITE } from "../data/site";

/** Warmes, ruhiges Motiv — Vollbild wie im Referenz-Layout */
const bg = {
  src: "https://images.unsplash.com/photo-1560066984-138dadb4c035?auto=format&fit=crop&w=2400&q=85",
};
---

<section class="hero hero--editorial hero--kalm" id="top" aria-labelledby="hero-heading">
  <div class="hero__media" aria-hidden="true">
    <img
      src={bg.src}
      alt=""
      width={2400}
      height={1350}
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="hero__bg-img"
    />
  </div>
  <div class="hero__scrim" aria-hidden="true"></div>
  <div class="hero__grain hero__grain--dark" aria-hidden="true"></div>

  <div class="hero__inner container">
    <div class="hero__stack" data-reveal style="--reveal-delay: 0ms">
      <p class="hero__intro">
        Willkommen in Ihrem Meisterbetrieb in {SITE.city}: ruhige Beratung, klare Hände, Schnitt und Farbe mit Substanz
        — Ihr wiederkehrender Moment für Haar, das sich im Alltag bewährt.
      </p>

      <h1 id="hero-heading" class="hero__title">
        <span class="hero__title-line">New Style</span>
        <span class="hero__title-line hero__title-line--sub">by Zeynep &amp; Faisal</span>
      </h1>

      <p class="hero__micro">
        <a class="hero__link" href="/preise/">Preise &amp; Leistungen</a>
        <span class="hero__dot" aria-hidden="true">·</span>
        <a class="hero__link" href="#leistungen">Kurzüberblick</a>
        <span class="hero__dot" aria-hidden="true">·</span>
        <a class="hero__link" href={SITE.bookingUrl} target="_blank" rel="noopener noreferrer">Termin bei Planity</a>
      </p>
    </div>
  </div>
</section>

<style>
  .hero--editorial.hero--kalm {
    position: relative;
    min-height: min(100vh, 980px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-top: calc(var(--header-h) + 1.5rem);
    padding-bottom: clamp(1.25rem, 4vh, 2.75rem);
    overflow: hidden;
    color: rgba(255, 255, 255, 0.96);
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 28%;
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(18, 14, 12, 0.35) 0%, rgba(18, 14, 12, 0.12) 42%, rgba(12, 9, 8, 0.82) 100%),
      linear-gradient(90deg, rgba(10, 8, 7, 0.65) 0%, transparent 62%);
  }

  .hero__grain--dark {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0.3;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E");
  }

  .hero__inner {
    position: relative;
    z-index: 3;
  }

  .hero__stack {
    max-width: min(52rem, 100%);
    padding-bottom: env(safe-area-inset-bottom, 0);
  }

  .hero__intro {
    margin: 0 0 1rem;
    max-width: 34rem;
    font-family: var(--font-body);
    font-size: clamp(0.62rem, 1.35vw, 0.72rem);
    font-weight: 600;
    line-height: 1.85;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
    text-shadow: 0 1px 20px rgba(0, 0, 0, 0.45);
  }

  .hero__title {
    margin: 0 0 1rem;
    padding: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.35rem, 7.5vw, 4.85rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: #fff;
    text-shadow: 0 4px 40px rgba(0, 0, 0, 0.4);
  }

  .hero__title-line {
    display: block;
  }

  .hero__title-line--sub {
    font-size: 0.52em;
    font-weight: 400;
    letter-spacing: 0.02em;
    margin-top: 0.12em;
    opacity: 0.92;
  }

  @media (min-width: 720px) {
    .hero__title-line {
      margin-left: -0.02em;
    }
  }

  .hero__micro {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.5rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.62);
  }

  .hero__dot {
    opacity: 0.5;
    user-select: none;
  }

  .hero__link {
    color: rgba(255, 255, 255, 0.88);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.35);
    padding-bottom: 0.12em;
    transition:
      color 0.25s ease,
      border-color 0.25s ease;
  }

  .hero__link:hover {
    color: #fff;
    border-bottom-color: rgba(255, 255, 255, 0.75);
  }

  @media (max-width: 520px) {
    .hero__intro {
      letter-spacing: 0.16em;
    }
  }
</style>
