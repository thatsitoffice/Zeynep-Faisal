---
import BookingButton from "./BookingButton.astro";
import { SITE } from "../data/site";

/** Vollflächiges Hero — hohe Auflösung für scharfe Darstellung */
const bg = {
  src: "https://images.unsplash.com/photo-1580618672591-eb180b1a973f?auto=format&fit=crop&w=2400&q=85",
  alt: "Salon-Atmosphäre — stellvertretend für New Style by Zeynep & Faisal",
};
---

<section class="hero hero--editorial hero--fullscreen" aria-labelledby="hero-heading">
  <div class="hero__media" aria-hidden="true">
    <img
      src={bg.src}
      alt=""
      width={2400}
      height={1350}
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="hero__bg-img"
    />
  </div>
  <div class="hero__scrim" aria-hidden="true"></div>
  <div class="hero__grain hero__grain--dark" aria-hidden="true"></div>

  <div class="hero__inner container">
    <div class="hero__copy" data-reveal style="--reveal-delay: 0ms">
      <p class="hero__kicker">{SITE.city} · {SITE.tagline}</p>

      <h1 id="hero-heading" class="hero__headline">
        Ruhig schön.<br />
        <span class="hero__headline-accent">Professionell geschnitten.</span>
      </h1>

      <p class="hero__lead">
        Meisterbetrieb in Gelsenkirchen: klare Beratung, ruhige Hände — Schnitt, Farbe und Pflege, die im Alltag funktionieren.
      </p>

      <div class="hero__cta-block">
        <p class="hero__cta-label">Online-Termin</p>
        <p class="hero__cta-text">
          Wählen Sie in Planity passende Zeit und Leistung — die Buchung öffnet sich in einem neuen Tab. Zahlung wie gewohnt vor Ort.
        </p>
        <div class="hero__actions">
          <BookingButton variant="heroSolid" />
          <a class="btn btn--hero-outline" href="#leistungen">Leistungen ansehen</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero--editorial.hero--fullscreen {
    position: relative;
    min-height: min(92vh, 920px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-top: calc(var(--header-h) + 2.5rem);
    padding-bottom: clamp(2.5rem, 7vh, 4.5rem);
    overflow: hidden;
    color: rgba(255, 255, 255, 0.96);
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(12, 10, 9, 0.45) 0%, rgba(12, 10, 9, 0.25) 38%, rgba(12, 10, 9, 0.72) 100%),
      linear-gradient(90deg, rgba(12, 10, 9, 0.55) 0%, transparent 55%);
  }

  .hero__grain--dark {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0.35;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E");
  }

  .hero__inner {
    position: relative;
    z-index: 3;
  }

  .hero__copy {
    max-width: 40rem;
  }

  .hero__kicker {
    margin: 0 0 1rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  .hero__headline {
    margin: 0 0 1.25rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.25rem, 6.2vw, 3.65rem);
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: #fff;
    text-shadow: 0 2px 28px rgba(0, 0, 0, 0.35);
  }

  .hero__headline-accent {
    font-weight: 400;
    color: rgba(255, 252, 248, 0.95);
  }

  .hero__lead {
    margin: 0 0 1.75rem;
    font-size: 1.0625rem;
    line-height: 1.75;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.88);
    max-width: 36rem;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.25);
  }

  .hero__cta-block {
    padding: 1.35rem 1.5rem;
    border-radius: var(--radius-md);
    background: rgba(8, 7, 6, 0.42);
    border: 1px solid rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(14px) saturate(1.1);
    -webkit-backdrop-filter: blur(14px) saturate(1.1);
    box-shadow: 0 24px 48px -24px rgba(0, 0, 0, 0.5);
  }

  .hero__cta-label {
    margin: 0 0 0.4rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
  }

  .hero__cta-text {
    margin: 0 0 1.15rem;
    font-size: 0.98rem;
    line-height: 1.68;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    align-items: center;
  }

  .hero__actions :global(.btn) {
    min-height: 3rem;
  }

  @media (max-width: 520px) {
    .hero__cta-block {
      padding: 1.15rem 1.15rem;
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__actions :global(.btn) {
      justify-content: center;
    }
  }
</style>
