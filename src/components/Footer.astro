---
import { SITE } from "../data/site";
import BookingButton from "./BookingButton.astro";
---

<footer class="site-footer section section--dark" id="kontakt">
  <div class="container">
    <div class="site-footer__grid" data-reveal>
      <div>
        <p class="eyebrow">Kontakt</p>
        <a
          class="site-footer__logo"
          href="/"
          aria-label={`${SITE.name} — ${SITE.tagline}, Startseite`}
        >
          <img
            src="/logo-zeynep-faisal.png"
            alt=""
            width="440"
            height="155"
            class="site-footer__logo-img"
            decoding="async"
          />
        </a>
        <p class="display-md site-footer__title">{SITE.name}</p>
        <p class="muted site-footer__tag">{SITE.tagline} · {SITE.city}</p>
        <p class="site-footer__address">{SITE.addressLine}</p>
        <p class="site-footer__hours">{SITE.openingHours}</p>
        <p>
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </p>
      </div>
      <div class="site-footer__book">
        <p class="lead" style="color: rgba(247,245,242,0.85); margin-top: 0;">
          Ihr nächster Termin ist nur wenige Klicks entfernt — wählen Sie Zeit, Leistung und Lieblingsstylist:in direkt in Planity.
        </p>
        <BookingButton variant="on-dark" />
      </div>
    </div>
    <p class="site-footer__legal">
      © {new Date().getFullYear()} {SITE.name}. Alle Rechte vorbehalten. ·{" "}
      <a href="/preise/">Preise &amp; Leistungen</a>
      {" · "}
      <a href={SITE.bookingUrl} target="_blank" rel="noopener noreferrer">Online-Buchung via Planity</a>
      {" · "}
      <a href="/impressum/">Impressum</a>
      {" · "}
      <a href="/datenschutz/">Datenschutz</a>
    </p>
  </div>
</footer>

<style>
  .site-footer__grid {
    display: grid;
    gap: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid rgba(247, 245, 242, 0.12);
  }

  @media (min-width: 800px) {
    .site-footer__grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .site-footer__logo {
    display: inline-block;
    line-height: 0;
    margin: 0 0 var(--space-sm);
    text-decoration: none;
  }

  .site-footer__logo:hover .site-footer__logo-img {
    opacity: 1;
  }

  .site-footer__logo-img {
    height: clamp(2.1rem, 5vw, 2.85rem);
    width: auto;
    max-width: min(240px, 72vw);
    object-fit: contain;
    display: block;
    /* Dunkles Logo auf dunklem Footer: hell zeichnen, Alpha vom PNG bleibt */
    filter: brightness(0) invert(1);
    opacity: 0.9;
    transition: opacity 0.25s ease;
  }

  .site-footer__title {
    margin-bottom: var(--space-xs);
  }

  .site-footer__tag {
    margin-top: 0;
    margin-bottom: var(--space-md);
  }

  .site-footer__address,
  .site-footer__hours {
    margin: 0 0 var(--space-sm);
    color: rgba(247, 245, 242, 0.78);
  }

  .site-footer__book {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .site-footer__legal {
    margin: var(--space-lg) auto 0;
    padding-bottom: var(--space-md);
    max-width: 36rem;
    text-align: center;
    font-size: 0.78rem;
    line-height: 1.55;
    color: rgba(247, 245, 242, 0.55);
  }

  .site-footer__legal a {
    color: rgba(247, 245, 242, 0.85);
  }
</style>
