---
import type { PriceCategory } from "../data/pricing";

interface Props {
  category: PriceCategory;
  /** Stagger für Scroll-Reveal (ms) */
  revealDelayMs?: number;
}

const { category, revealDelayMs = 0 } = Astro.props;
---

<article
  class="price-cat card"
  id={category.id}
  data-reveal
  style={revealDelayMs ? `--reveal-delay: ${revealDelayMs}ms` : undefined}
>
  <h2 class="display-md price-cat__title">{category.title}</h2>
  {category.intro && <p class="price-cat__intro muted">{category.intro}</p>}
  <div class="price-cat__table-wrap">
    <table class="price-table">
      <thead>
        <tr>
          <th scope="col">Leistung</th>
          <th scope="col">Dauer</th>
          <th scope="col">Preis</th>
        </tr>
      </thead>
      <tbody>
        {
          category.rows.map((r) => (
            <tr>
              <td>
                {r.name}
                {r.note && (
                  <span class="price-cat__note muted">
                    <br />
                    <span class="price-cat__note-inner">{r.note}</span>
                  </span>
                )}
              </td>
              <td>{r.duration ?? "—"}</td>
              <td>{r.price}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</article>

<style>
  .price-cat {
    margin: 0;
    scroll-margin-top: calc(var(--header-h) + var(--space-md));
  }

  .price-cat__title {
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    margin: 0 0 var(--space-sm);
  }

  .price-cat__intro {
    margin: 0 0 var(--space-md);
    font-size: 0.95rem;
    line-height: 1.55;
    max-width: 42rem;
  }

  .price-cat__table-wrap {
    overflow-x: auto;
    margin-inline: 0;
    padding-inline: 0;
  }

  .price-table th:nth-child(2),
  .price-table td:nth-child(2) {
    white-space: nowrap;
    width: 1%;
  }

  .price-table th:last-child,
  .price-table td:last-child {
    text-align: right;
  }

  .price-cat__note {
    font-size: 0.82rem;
    font-weight: 400;
  }

  .price-cat__note-inner {
    display: inline-block;
    margin-top: 0.2rem;
  }
</style>
