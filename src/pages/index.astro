---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import TrustSection from "../components/TrustSection.astro";
import PricingPreviewSection from "../components/PricingPreviewSection.astro";
import ProductsSection from "../components/ProductsSection.astro";
import FeatureGlass from "../components/FeatureGlass.astro";
import MoodGallery from "../components/MoodGallery.astro";
import TestimonialsSection from "../components/TestimonialsSection.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../data/site";
import { GOOGLE_REVIEWS_FALLBACK } from "../data/google";

/**
 * SEO: Titel & Description — bei Go-Live an echte Keywords / USPs anpassen.
 */
const pageTitle =
  "New Style by Zeynep & Faisal | Meisterbetrieb Friseur Gelsenkirchen — Termin online buchen";
const pageDescription =
  "Premium-Friseur in Gelsenkirchen: Schnitt, Farbe & Pflege auf Meisterniveau. Ruhige Beratung, transparente Preise — Termin sicher über Planity buchen.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HairSalon",
  name: `${SITE.name} — ${SITE.tagline}`,
  description: pageDescription,
  url: SITE.canonicalBase,
  image: `${SITE.canonicalBase}/og-placeholder.svg`,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Cranger Str. 316",
    addressLocality: SITE.city,
    postalCode: "45891",
    addressCountry: "DE",
  },
  areaServed: SITE.region,
  priceRange: "€€",
  makesOffer: {
    "@type": "Offer",
    url: SITE.bookingUrl,
    name: "Online-Terminbuchung",
  },
  /** An GOOGLE_REVIEWS_FALLBACK in google.ts anpassen, wenn keine API genutzt wird */
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: GOOGLE_REVIEWS_FALLBACK.rating,
    reviewCount: GOOGLE_REVIEWS_FALLBACK.userRatingCount,
    bestRating: 5,
    worstRating: 1,
  },
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <Header />
  <main id="main">
    <Hero />
    <TrustSection />
    <FeatureGlass />
    <PricingPreviewSection />
    <TestimonialsSection />
    <MoodGallery />
    <ProductsSection />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
