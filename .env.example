# Optional: echte Bewertungstexte beim statischen Build von Google Places API (New) laden.
# In Google Cloud: Places API (New) aktivieren, Abrechnung einrichten, Schlüssel einschränken.
# Cloudflare Pages / GitHub Actions: als Build-Umgebungsvariablen hinterlegen (nicht committen).

GOOGLE_PLACES_API_KEY=
# Place-ID (Format ChIJ…), z. B. über den Place-ID-Finder
GOOGLE_PLACE_ID=
